<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Luna.Desktop.Sample.ViewModels.Samples"
             xmlns:controls="using:Luna.Desktop.Controls"
             x:Class="Luna.Desktop.Sample.Views.Samples.AnchorSampleView"
             x:DataType="vm:AnchorSampleViewModel">
  <StackPanel Spacing="16">
    <Border Classes="sample-card">
      <StackPanel Spacing="12">
        <TextBlock Text="基本锚点" Classes="sample-title" />
        <TextBlock Text="Anchor 提供页面内快速跳转定位功能，左侧导航链接 + 右侧滚动内容区域。点击链接平滑滚动到对应章节，滚动内容自动高亮当前章节。"
                   Classes="sample-caption" TextWrapping="Wrap" />
        <Border Height="400"
                BorderBrush="{DynamicResource Luna.Brush.Border.Default}"
                BorderThickness="1"
                CornerRadius="{DynamicResource Luna.Radius.Default}">
          <Grid ColumnDefinitions="180,*">
            <controls:Anchor Name="PART_Anchor"
                             ItemsSource="{Binding Sections}"
                             DisplayMemberPath="Title">
              <controls:Anchor.ItemContainerTheme>
                <ControlTheme TargetType="controls:AnchorItem">
                  <Setter Property="AnchorId" Value="{Binding AnchorId}" />
                </ControlTheme>
              </controls:Anchor.ItemContainerTheme>
            </controls:Anchor>

            <ScrollViewer Name="PART_ScrollViewer" Grid.Column="1"
                          Margin="24,16"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding Sections}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:AnchorSection">
                    <StackPanel Spacing="8"
                                Margin="0,0,0,32"
                                controls:Anchor.AnchorId="{Binding AnchorId}">
                      <TextBlock Text="{Binding Title}"
                                 FontSize="{DynamicResource Luna.FontSize.Title.Small}"
                                 FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                                 Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
                      <TextBlock Text="{Binding Description}"
                                 TextWrapping="Wrap"
                                 FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                                 Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                                 LineHeight="22" />
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Grid>
        </Border>
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
