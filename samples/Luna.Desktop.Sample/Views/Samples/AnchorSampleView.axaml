<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Luna.Desktop.Sample.ViewModels.Samples"
             xmlns:controls="using:Luna.Desktop.Controls"
             x:Class="Luna.Desktop.Sample.Views.Samples.AnchorSampleView"
             x:DataType="vm:AnchorSampleViewModel">
  <StackPanel Spacing="16">
    <Border Classes="sample-card">
      <StackPanel Spacing="12">
        <TextBlock Text="锚点导航" Classes="sample-title" />
        <TextBlock Text="Anchor 提供页面内快速跳转定位功能，左侧导航 + 右侧内容区域。" Classes="sample-caption" />
        <Border Height="300" BorderBrush="{DynamicResource Luna.Brush.Border.Default}" BorderThickness="1"
                CornerRadius="{DynamicResource Luna.Radius.Default}">
          <controls:Anchor>
            <ScrollViewer>
              <StackPanel Spacing="24" Margin="16">
                <TextBlock Text="第一节：概述" FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                           Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
                <TextBlock Text="Luna Desktop 是一套基于 Avalonia UI 的桌面端组件库，遵循 TDesign 设计规范。提供丰富的控件、主题和布局支持，帮助开发者快速构建美观的桌面应用。"
                           TextWrapping="Wrap" Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />

                <TextBlock Text="第二节：特性" FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                           Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
                <TextBlock Text="支持明暗主题切换、Token 化设计、MVVM 绑定、响应式布局。覆盖基础、表单、数据展示、反馈和导航五大控件域。"
                           TextWrapping="Wrap" Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />

                <TextBlock Text="第三节：快速开始" FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                           Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
                <TextBlock Text="通过 NuGet 安装 Luna.Desktop 包，在 App.axaml 中引用主题资源，即可开始使用所有控件。"
                           TextWrapping="Wrap" Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
              </StackPanel>
            </ScrollViewer>
          </controls:Anchor>
        </Border>
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
