<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Luna.Desktop.Sample.ViewModels.Samples"
             xmlns:controls="using:Luna.Desktop.Controls"
             x:Class="Luna.Desktop.Sample.Views.Samples.CascaderSampleView"
             x:DataType="vm:CascaderSampleViewModel">
  <ScrollViewer>
    <StackPanel Spacing="16" Margin="0,0,0,24">
      <Border Classes="sample-card">
        <StackPanel Spacing="12">
          <TextBlock Text="基本级联选择" Classes="sample-title" />
          <TextBlock Text="点击输入框展开下拉面板，逐级选择省/市/区。" Classes="sample-caption" />
          <controls:Cascader Width="320" HorizontalAlignment="Left"
                             Options="{Binding Options}"
                             Placeholder="请选择地区" />
        </StackPanel>
      </Border>

      <Border Classes="sample-card">
        <StackPanel Spacing="12">
          <TextBlock Text="自定义占位符" Classes="sample-title" />
          <TextBlock Text="通过 Placeholder 属性设置自定义提示文字。" Classes="sample-caption" />
          <StackPanel Spacing="8">
            <controls:Cascader Width="320" HorizontalAlignment="Left"
                               Options="{Binding Options}"
                               Placeholder="选择省份 / 城市 / 区县" />
            <controls:Cascader Width="320" HorizontalAlignment="Left"
                               Options="{Binding Options}"
                               Placeholder="Pick a region" />
          </StackPanel>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
