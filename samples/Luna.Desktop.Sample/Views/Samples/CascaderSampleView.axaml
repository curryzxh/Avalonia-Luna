<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Luna.Desktop.Sample.ViewModels.Samples"
             xmlns:controls="using:Luna.Desktop.Controls"
             x:Class="Luna.Desktop.Sample.Views.Samples.CascaderSampleView"
             x:DataType="vm:CascaderSampleViewModel">
  <StackPanel Spacing="16">
    <Border Classes="sample-card">
      <StackPanel Spacing="12">
        <TextBlock Text="级联选择" Classes="sample-title" />
        <TextBlock Text="Cascader 用于多级数据联动选择，如省市区选择。当前展示 TreeView 方式实现。" Classes="sample-caption" />
        <controls:Cascader Placeholder="{Binding SelectedPath}" />
      </StackPanel>
    </Border>

    <Border Classes="sample-card">
      <StackPanel Spacing="12">
        <TextBlock Text="数据结构展示" Classes="sample-title" />
        <TextBlock Text="级联选择器支持多级嵌套数据。" Classes="sample-caption" />
        <TreeView MaxWidth="360" HorizontalAlignment="Left">
          <TreeViewItem ItemsSource="{Binding Items}" Header="中国">
            <TreeViewItem.ItemTemplate>
              <DataTemplate>
                <TreeViewItem ItemsSource="{Binding Children}" Header="{Binding Label}" IsExpanded="True">
                  <TreeViewItem.ItemTemplate>
                    <DataTemplate>
                      <TreeViewItem ItemsSource="{Binding Children}" Header="{Binding Label}" IsExpanded="True">
                        <TreeViewItem.ItemTemplate>
                          <DataTemplate>
                            <TreeViewItem Header="{Binding Label}" />
                          </DataTemplate>
                        </TreeViewItem.ItemTemplate>
                      </TreeViewItem>
                    </DataTemplate>
                  </TreeViewItem.ItemTemplate>
                </TreeViewItem>
              </DataTemplate>
            </TreeViewItem.ItemTemplate>
          </TreeViewItem>
        </TreeView>
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
