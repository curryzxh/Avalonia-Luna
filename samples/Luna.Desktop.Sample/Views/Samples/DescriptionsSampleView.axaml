<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Luna.Desktop.Sample.ViewModels.Samples"
             xmlns:controls="using:Luna.Desktop.Controls"
             x:Class="Luna.Desktop.Sample.Views.Samples.DescriptionsSampleView"
             x:DataType="vm:DescriptionsSampleViewModel">
  <ScrollViewer>
    <StackPanel Spacing="16" Margin="0,0,0,24">
      <Border Classes="sample-card">
        <StackPanel Spacing="12">
          <TextBlock Text="基础描述列表" Classes="sample-title" />
          <TextBlock Text="使用 Descriptions 控件展示结构化数据，ColumnCount 控制列数。" Classes="sample-caption" />
          <controls:Descriptions ItemsSource="{Binding Items}"
                                  Title="{Binding Title}"
                                  ColumnCount="{Binding ColumnCount}"
                                  LabelWidth="{Binding LabelWidth}"
                                  MaxWidth="600" HorizontalAlignment="Left">
            <controls:Descriptions.ItemTemplate>
              <DataTemplate x:DataType="controls:DescriptionItem">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="{Binding Label}"
                             Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                             Width="{Binding LabelWidth, RelativeSource={RelativeSource AncestorType=controls:Descriptions}}" />
                  <TextBlock Text="{Binding Value}" />
                </StackPanel>
              </DataTemplate>
            </controls:Descriptions.ItemTemplate>
          </controls:Descriptions>
        </StackPanel>
      </Border>

      <Border Classes="sample-card">
        <StackPanel Spacing="12">
          <TextBlock Text="自定义配置" Classes="sample-title" />
          <StackPanel Spacing="8" Orientation="Horizontal">
            <StackPanel Spacing="4">
              <TextBlock Text="列数" Classes="sample-caption" />
              <Slider Minimum="1" Maximum="4" Value="{Binding ColumnCount}" Width="120" />
            </StackPanel>
            <StackPanel Spacing="4" Margin="16,0,0,0">
              <TextBlock Text="标签宽度" Classes="sample-caption" />
              <Slider Minimum="60" Maximum="200" Value="{Binding LabelWidth}" Width="120" />
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Classes="sample-card">
        <StackPanel Spacing="12">
          <TextBlock Text="带边框描述列表" Classes="sample-title" />
          <TextBlock Text="使用 UniformGrid + Border 实现带边框的表格化描述列表。" Classes="sample-caption" />
          <ItemsControl ItemsSource="{Binding Items}" MaxWidth="600" HorizontalAlignment="Left">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <UniformGrid Columns="2" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="controls:DescriptionItem">
                <Border BorderBrush="{DynamicResource Luna.Brush.Border.Divider}" BorderThickness="1" Margin="-1,-1,0,0">
                  <Grid ColumnDefinitions="100,*">
                    <Border BorderBrush="{DynamicResource Luna.Brush.Border.Divider}" BorderThickness="0,0,1,0" Padding="12,8" Background="{DynamicResource Luna.Brush.Background.Page}">
                      <TextBlock Text="{Binding Label}" Foreground="{DynamicResource Luna.Brush.Text.Secondary}" VerticalAlignment="Center" />
                    </Border>
                    <Border Grid.Column="1" Padding="12,8">
                      <TextBlock Text="{Binding Value}" Foreground="{DynamicResource Luna.Brush.Text.Primary}" VerticalAlignment="Center" />
                    </Border>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
