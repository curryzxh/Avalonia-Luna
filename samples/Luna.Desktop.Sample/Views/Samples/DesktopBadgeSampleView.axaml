<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:luna="clr-namespace:Luna.Desktop.Controls;assembly=Luna.Desktop"
             xmlns:vm="using:Luna.Desktop.Sample.ViewModels.Samples"
             x:Class="Luna.Desktop.Sample.Views.Samples.DesktopBadgeSampleView"
             x:DataType="vm:DesktopBadgeSampleViewModel">
  <StackPanel Spacing="16">
    <Border Classes="sample-card">
      <StackPanel Spacing="12">
        <TextBlock Text="数字徽标" Classes="sample-title" />
        <TextBlock Text="TDesign Badge 的 count、dot、maxCount 可先映射为 DesktopBadge 文本和位置组合。" Classes="sample-caption" />
        <WrapPanel>
          <luna:DesktopBadge Text="8" Margin="0,0,12,8" />
          <luna:DesktopBadge Text="99+" Margin="0,0,12,8" />
          <luna:DesktopBadge Text="NEW" Classes="brand" Margin="0,0,12,8" />
        </WrapPanel>
      </StackPanel>
    </Border>

    <Border Classes="sample-card">
      <StackPanel Spacing="12">
        <TextBlock Text="标签组合" Classes="sample-title" />
        <WrapPanel>
          <Border Classes="tag primary" Margin="0,0,10,8">
            <TextBlock Text="审批中" Foreground="{DynamicResource Luna.Brush.Brand}" />
          </Border>
          <Border Classes="tag success" Margin="0,0,10,8">
            <TextBlock Text="已上线" Foreground="{DynamicResource Luna.Brush.Success}" />
          </Border>
          <Border Classes="tag warning" Margin="0,0,10,8">
            <TextBlock Text="需复核" Foreground="{DynamicResource Luna.Brush.Warning}" />
          </Border>
        </WrapPanel>
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
