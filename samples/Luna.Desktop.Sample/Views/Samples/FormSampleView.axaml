<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Luna.Desktop.Sample.ViewModels.Samples"
             xmlns:controls="using:Luna.Desktop.Controls"
             x:Class="Luna.Desktop.Sample.Views.Samples.FormSampleView"
             x:DataType="vm:FormSampleViewModel">
  <ScrollViewer>
    <StackPanel Spacing="16" Margin="0,0,0,24">
      <Border Classes="sample-card">
        <StackPanel Spacing="16" MaxWidth="480" HorizontalAlignment="Left">
          <TextBlock Text="水平表单" Classes="sample-title" />
          <TextBlock Text="使用 FormItem 管理标签对齐、必填标记和错误信息。" Classes="sample-caption" />
          <StackPanel Spacing="16">
            <controls:FormItem Label="姓名" IsRequired="True" ErrorMessage="{Binding NameError}" LabelWidth="80">
              <TextBox Text="{Binding Name, Mode=TwoWay}" Watermark="请输入姓名" />
            </controls:FormItem>
            <controls:FormItem Label="邮箱" IsRequired="True" ErrorMessage="{Binding EmailError}" LabelWidth="80">
              <TextBox Text="{Binding Email, Mode=TwoWay}" Watermark="请输入邮箱地址" />
            </controls:FormItem>
            <controls:FormItem Label="手机号" IsRequired="True" ErrorMessage="{Binding PhoneError}" LabelWidth="80">
              <TextBox Text="{Binding Phone, Mode=TwoWay}" Watermark="请输入手机号" />
            </controls:FormItem>
            <controls:FormItem Label="备注" LabelWidth="80">
              <TextBox Text="{Binding Remark, Mode=TwoWay}" AcceptsReturn="True" Height="80" Watermark="请输入备注（选填）" />
            </controls:FormItem>
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="80,0,0,0">
              <Button Classes="primary" Content="提交" Command="{Binding SubmitCommand}" />
              <Button Content="重置" Command="{Binding ResetCommand}" />
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Classes="sample-card">
        <StackPanel Spacing="16" MaxWidth="480" HorizontalAlignment="Left">
          <TextBlock Text="垂直表单" Classes="sample-title" />
          <TextBlock Text="设置 LabelAlign=Vertical 使标签在输入框上方显示。" Classes="sample-caption" />
          <StackPanel Spacing="16">
            <controls:FormItem Label="用户名" IsRequired="True" LabelAlign="Vertical">
              <TextBox Text="{Binding Name, Mode=TwoWay}" Watermark="请输入用户名" />
            </controls:FormItem>
            <controls:FormItem Label="邮箱地址" LabelAlign="Vertical">
              <TextBox Text="{Binding Email, Mode=TwoWay}" Watermark="请输入邮箱" />
            </controls:FormItem>
          </StackPanel>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
