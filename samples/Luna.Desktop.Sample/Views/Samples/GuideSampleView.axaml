<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Luna.Desktop.Sample.ViewModels.Samples"
             xmlns:controls="using:Luna.Desktop.Controls"
             x:Class="Luna.Desktop.Sample.Views.Samples.GuideSampleView"
             x:DataType="vm:GuideSampleViewModel">
  <StackPanel Spacing="16">
    <Border Classes="sample-card">
      <StackPanel Spacing="12">
        <TextBlock Text="新手引导" Classes="sample-title" />
        <TextBlock Text="Guide 通过遮罩高亮逐步引导用户了解功能。点击按钮开始引导。" Classes="sample-caption" />
        <Button Content="开始引导" Classes="primary" Command="{ReflectionBinding StartGuideCommand}" />
      </StackPanel>
    </Border>

    <Border Classes="sample-card">
      <StackPanel Spacing="12">
        <TextBlock Text="引导预览" Classes="sample-title" />
        <controls:Guide IsVisible="{Binding IsGuideVisible}"
                        Title="{Binding GuideTitle}"
                        Description="{Binding GuideDescription}"
                        CurrentStep="{Binding CurrentStep}"
                        TotalSteps="{Binding TotalSteps}"
                        MaxWidth="500"
                        MaxHeight="300">
          <StackPanel Spacing="16">
            <TextBlock Text="这是需要引导的功能区域" FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
            <TextBlock Text="引导遮罩会覆盖在其他内容之上，高亮展示当前步骤。" Foreground="{DynamicResource Luna.Brush.Text.Secondary}" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="下一步" Classes="primary" Command="{ReflectionBinding NextStepCommand}" />
              <Button Content="跳过" Classes="link" Command="{ReflectionBinding CloseGuideCommand}" />
            </StackPanel>
          </StackPanel>
        </controls:Guide>
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
