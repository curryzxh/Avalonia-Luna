<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Luna.Desktop.Sample.ViewModels.Samples"
             x:Class="Luna.Desktop.Sample.Views.Samples.ImageSampleView"
             x:DataType="vm:ImageSampleViewModel">
  <ScrollViewer>
    <StackPanel Spacing="16" Margin="0,0,0,24">
      <Border Classes="sample-card">
        <StackPanel Spacing="12">
          <TextBlock Text="图片占位" Classes="sample-title" />
          <TextBlock Text="使用 Luna 样式的图片占位容器，支持默认圆角和圆形两种模式。" Classes="sample-caption" />
          <WrapPanel>
            <Border Classes="image-placeholder" Width="120" Height="120" Margin="0,0,12,8">
              <TextBlock Text="默认圆角" HorizontalAlignment="Center" VerticalAlignment="Center"
                         Foreground="{DynamicResource Luna.Brush.Text.Placeholder}"
                         FontSize="{DynamicResource Luna.FontSize.Body.Small}" />
            </Border>
            <Border Classes="image-placeholder round" Width="120" Height="120" Margin="0,0,12,8">
              <TextBlock Text="圆形" HorizontalAlignment="Center" VerticalAlignment="Center"
                         Foreground="{DynamicResource Luna.Brush.Text.Placeholder}"
                         FontSize="{DynamicResource Luna.FontSize.Body.Small}" />
            </Border>
            <Border Classes="image-placeholder" Width="160" Height="100" Margin="0,0,12,8">
              <TextBlock Text="横向占位" HorizontalAlignment="Center" VerticalAlignment="Center"
                         Foreground="{DynamicResource Luna.Brush.Text.Placeholder}"
                         FontSize="{DynamicResource Luna.FontSize.Body.Small}" />
            </Border>
          </WrapPanel>
        </StackPanel>
      </Border>

      <Border Classes="sample-card">
        <StackPanel Spacing="12">
          <TextBlock Text="加载失败" Classes="sample-title" />
          <TextBlock Text="图片加载失败时展示错误状态和重试按钮。" Classes="sample-caption" />
          <Border Classes="image-placeholder" Width="160" Height="100" Margin="0,0,12,8">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
              <TextBlock Text="加载失败" HorizontalAlignment="Center"
                         Foreground="{DynamicResource Luna.Brush.Text.Placeholder}"
                         FontSize="{DynamicResource Luna.FontSize.Body.Small}" />
              <Button Content="重新加载" Classes="text small" HorizontalAlignment="Center" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <Border Classes="sample-card">
        <StackPanel Spacing="12">
          <TextBlock Text="不同 Stretch 模式" Classes="sample-title" />
          <TextBlock Text="Image 控件支持 Uniform / Fill / UniformToFill / None 四种缩放模式。" Classes="sample-caption" />
          <WrapPanel>
            <StackPanel Margin="0,0,16,8" Spacing="4" HorizontalAlignment="Center">
              <Border Classes="image-placeholder" Width="100" Height="100">
                <TextBlock Text="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource Luna.Brush.Text.Placeholder}"
                           FontSize="{DynamicResource Luna.FontSize.Body.Small}" />
              </Border>
              <TextBlock Text="Uniform" HorizontalAlignment="Center"
                         FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                         Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
            </StackPanel>
            <StackPanel Margin="0,0,16,8" Spacing="4" HorizontalAlignment="Center">
              <Border Classes="image-placeholder" Width="100" Height="100">
                <TextBlock Text="Fill" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource Luna.Brush.Text.Placeholder}"
                           FontSize="{DynamicResource Luna.FontSize.Body.Small}" />
              </Border>
              <TextBlock Text="Fill" HorizontalAlignment="Center"
                         FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                         Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
            </StackPanel>
            <StackPanel Margin="0,0,16,8" Spacing="4" HorizontalAlignment="Center">
              <Border Classes="image-placeholder" Width="100" Height="100">
                <TextBlock Text="Crop" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource Luna.Brush.Text.Placeholder}"
                           FontSize="{DynamicResource Luna.FontSize.Body.Small}" />
              </Border>
              <TextBlock Text="UniformToFill" HorizontalAlignment="Center"
                         FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                         Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
            </StackPanel>
            <StackPanel Margin="0,0,16,8" Spacing="4" HorizontalAlignment="Center">
              <Border Classes="image-placeholder" Width="100" Height="100">
                <TextBlock Text="None" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource Luna.Brush.Text.Placeholder}"
                           FontSize="{DynamicResource Luna.FontSize.Body.Small}" />
              </Border>
              <TextBlock Text="None" HorizontalAlignment="Center"
                         FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                         Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
            </StackPanel>
          </WrapPanel>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
