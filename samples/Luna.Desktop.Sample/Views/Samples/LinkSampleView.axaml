<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Luna.Desktop.Sample.ViewModels.Samples"
             x:Class="Luna.Desktop.Sample.Views.Samples.LinkSampleView"
             x:DataType="vm:LinkSampleViewModel">
  <StackPanel Spacing="16">
    <Border Classes="sample-card">
      <StackPanel Spacing="12">
        <TextBlock Text="基础链接" Classes="sample-title" />
        <TextBlock Text="使用 Button Classes=&quot;link&quot; 渲染文字链接，默认品牌色，悬停变深。" Classes="sample-caption" />
        <WrapPanel>
          <Button Classes="link" Content="默认链接" Margin="0,0,16,8" />
          <Button Classes="link underline" Content="下划线链接" Margin="0,0,16,8" />
          <Button Classes="link" Content="禁用链接" IsEnabled="False" Margin="0,0,16,8" />
        </WrapPanel>
      </StackPanel>
    </Border>

    <Border Classes="sample-card">
      <StackPanel Spacing="12">
        <TextBlock Text="语义变体" Classes="sample-title" />
        <TextBlock Text="通过附加 Classes 指定 danger / success / warning 等语义。" Classes="sample-caption" />
        <WrapPanel>
          <Button Classes="link danger" Content="危险链接" Margin="0,0,16,8" />
          <Button Classes="link success" Content="成功链接" Margin="0,0,16,8" />
          <Button Classes="link warning" Content="警告链接" Margin="0,0,16,8" />
        </WrapPanel>
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
