<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Luna.Desktop.Sample.ViewModels.Samples"
             x:Class="Luna.Desktop.Sample.Views.Samples.MenuSampleView"
             x:DataType="vm:MenuSampleViewModel">
  <StackPanel Spacing="16">
    <Border Classes="sample-card">
      <StackPanel Spacing="12">
        <TextBlock Text="顶部导航菜单" Classes="sample-title" />
        <TextBlock Text="基于 Avalonia Menu 皮肤化，支持多级子菜单。" Classes="sample-caption" />
        <Menu>
          <MenuItem Header="文件">
            <MenuItem Header="新建" />
            <MenuItem Header="打开" />
            <MenuItem Header="保存" />
            <Separator />
            <MenuItem Header="退出" />
          </MenuItem>
          <MenuItem Header="编辑">
            <MenuItem Header="撤销" />
            <MenuItem Header="重做" />
            <Separator />
            <MenuItem Header="剪切" />
            <MenuItem Header="复制" />
            <MenuItem Header="粘贴" />
          </MenuItem>
          <MenuItem Header="视图">
            <MenuItem Header="放大" />
            <MenuItem Header="缩小" />
            <MenuItem Header="重置缩放" />
          </MenuItem>
          <MenuItem Header="帮助">
            <MenuItem Header="文档" />
            <MenuItem Header="关于" />
          </MenuItem>
        </Menu>
      </StackPanel>
    </Border>

    <Border Classes="sample-card">
      <StackPanel Spacing="12">
        <TextBlock Text="交互反馈" Classes="sample-title" />
        <TextBlock Text="{Binding LastAction, StringFormat='最近操作：{0}'}" Classes="sample-caption" />
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
