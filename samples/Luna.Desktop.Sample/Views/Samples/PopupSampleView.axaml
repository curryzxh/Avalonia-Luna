<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Luna.Desktop.Sample.ViewModels.Samples"
             xmlns:controls="using:Luna.Desktop.Controls"
             x:Class="Luna.Desktop.Sample.Views.Samples.PopupSampleView"
             x:DataType="vm:PopupSampleViewModel">
  <ScrollViewer>
    <StackPanel Spacing="16" Margin="0,0,0,24">
      <Border Classes="sample-card">
        <StackPanel Spacing="12">
          <TextBlock Text="点击触发" Classes="sample-title" />
          <TextBlock Text="默认触发方式，点击触发元素切换弹出层。" Classes="sample-caption" />
          <controls:LunaPopup IsOpen="{Binding IsClickOpen, Mode=TwoWay}"
                              Placement="Bottom"
                              Trigger="Click">
            <controls:LunaPopup.Content>
              <Button Content="点击弹出" />
            </controls:LunaPopup.Content>
            <controls:LunaPopup.PopupContent>
              <StackPanel Spacing="8" MinWidth="200">
                <TextBlock Text="弹出层内容" FontWeight="{DynamicResource Luna.FontWeight.SemiBold}" />
                <TextBlock Text="点击外部区域可关闭弹出层。"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
              </StackPanel>
            </controls:LunaPopup.PopupContent>
          </controls:LunaPopup>
        </StackPanel>
      </Border>

      <Border Classes="sample-card">
        <StackPanel Spacing="12">
          <TextBlock Text="悬停触发" Classes="sample-title" />
          <TextBlock Text="鼠标悬停时自动弹出，移出后关闭。" Classes="sample-caption" />
          <controls:LunaPopup IsOpen="{Binding IsHoverOpen, Mode=TwoWay}"
                              Placement="Top"
                              Trigger="Hover">
            <controls:LunaPopup.Content>
              <Border Background="{DynamicResource Luna.Brush.Background.Component}"
                      BorderBrush="{DynamicResource Luna.Brush.Border.Default}"
                      BorderThickness="1"
                      CornerRadius="{DynamicResource Luna.Radius.Default}"
                      Padding="12,8">
                <TextBlock Text="鼠标悬停此处" />
              </Border>
            </controls:LunaPopup.Content>
            <controls:LunaPopup.PopupContent>
              <TextBlock Text="悬停触发的弹出内容" Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
            </controls:LunaPopup.PopupContent>
          </controls:LunaPopup>
        </StackPanel>
      </Border>

      <Border Classes="sample-card">
        <StackPanel Spacing="12">
          <TextBlock Text="手动触发" Classes="sample-title" />
          <TextBlock Text="通过 IsOpen 属性手动控制弹出层的显示与隐藏。" Classes="sample-caption" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <controls:LunaPopup IsOpen="{Binding IsManualOpen, Mode=TwoWay}"
                                Placement="Bottom"
                                Trigger="Manual">
              <controls:LunaPopup.Content>
                <Border Background="{DynamicResource Luna.Brush.Background.Component}"
                        BorderBrush="{DynamicResource Luna.Brush.Brand}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource Luna.Radius.Default}"
                        Padding="12,8">
                  <TextBlock Text="手动弹出目标" Foreground="{DynamicResource Luna.Brush.Brand}" />
                </Border>
              </controls:LunaPopup.Content>
              <controls:LunaPopup.PopupContent>
                <StackPanel Spacing="8">
                  <TextBlock Text="手动控制的弹出层" FontWeight="{DynamicResource Luna.FontWeight.SemiBold}" />
                  <TextBlock Text="通过按钮手动切换 IsOpen 属性。"
                             Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
                </StackPanel>
              </controls:LunaPopup.PopupContent>
            </controls:LunaPopup>
            <Button Content="切换弹出" Command="{Binding ToggleManualCommand}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Classes="sample-card">
        <StackPanel Spacing="12">
          <TextBlock Text="不同弹出方向" Classes="sample-title" />
          <TextBlock Text="通过 Placement 属性控制弹出方向：Bottom / Top / Left / Right / Center。" Classes="sample-caption" />
          <WrapPanel Orientation="Horizontal" ItemWidth="160" ItemHeight="160">
            <Border Margin="8"
                    Background="{DynamicResource Luna.Brush.Background.Component}"
                    CornerRadius="{DynamicResource Luna.Radius.Default}"
                    BorderBrush="{DynamicResource Luna.Brush.Border.Default}"
                    BorderThickness="1">
              <controls:LunaPopup Placement="Top" Trigger="Click">
                <controls:LunaPopup.Content>
                  <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                    <TextBlock Text="Top" HorizontalAlignment="Center"
                               Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                               FontSize="{DynamicResource Luna.FontSize.Body.Small}" />
                    <Button Content="上方弹出" />
                  </StackPanel>
                </controls:LunaPopup.Content>
                <controls:LunaPopup.PopupContent>
                  <TextBlock Text="Top Popup" Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
                </controls:LunaPopup.PopupContent>
              </controls:LunaPopup>
            </Border>

            <Border Margin="8"
                    Background="{DynamicResource Luna.Brush.Background.Component}"
                    CornerRadius="{DynamicResource Luna.Radius.Default}"
                    BorderBrush="{DynamicResource Luna.Brush.Border.Default}"
                    BorderThickness="1">
              <controls:LunaPopup Placement="Bottom" Trigger="Click">
                <controls:LunaPopup.Content>
                  <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                    <TextBlock Text="Bottom" HorizontalAlignment="Center"
                               Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                               FontSize="{DynamicResource Luna.FontSize.Body.Small}" />
                    <Button Content="下方弹出" />
                  </StackPanel>
                </controls:LunaPopup.Content>
                <controls:LunaPopup.PopupContent>
                  <TextBlock Text="Bottom Popup" Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
                </controls:LunaPopup.PopupContent>
              </controls:LunaPopup>
            </Border>

            <Border Margin="8"
                    Background="{DynamicResource Luna.Brush.Background.Component}"
                    CornerRadius="{DynamicResource Luna.Radius.Default}"
                    BorderBrush="{DynamicResource Luna.Brush.Border.Default}"
                    BorderThickness="1">
              <controls:LunaPopup Placement="Left" Trigger="Click">
                <controls:LunaPopup.Content>
                  <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                    <TextBlock Text="Left" HorizontalAlignment="Center"
                               Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                               FontSize="{DynamicResource Luna.FontSize.Body.Small}" />
                    <Button Content="左侧弹出" />
                  </StackPanel>
                </controls:LunaPopup.Content>
                <controls:LunaPopup.PopupContent>
                  <TextBlock Text="Left Popup" Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
                </controls:LunaPopup.PopupContent>
              </controls:LunaPopup>
            </Border>

            <Border Margin="8"
                    Background="{DynamicResource Luna.Brush.Background.Component}"
                    CornerRadius="{DynamicResource Luna.Radius.Default}"
                    BorderBrush="{DynamicResource Luna.Brush.Border.Default}"
                    BorderThickness="1">
              <controls:LunaPopup Placement="Right" Trigger="Click">
                <controls:LunaPopup.Content>
                  <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                    <TextBlock Text="Right" HorizontalAlignment="Center"
                               Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                               FontSize="{DynamicResource Luna.FontSize.Body.Small}" />
                    <Button Content="右侧弹出" />
                  </StackPanel>
                </controls:LunaPopup.Content>
                <controls:LunaPopup.PopupContent>
                  <TextBlock Text="Right Popup" Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
                </controls:LunaPopup.PopupContent>
              </controls:LunaPopup>
            </Border>
          </WrapPanel>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
