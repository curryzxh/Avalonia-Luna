<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Luna.Desktop.Sample.ViewModels.Samples"
             xmlns:controls="using:Luna.Desktop.Controls"
             x:Class="Luna.Desktop.Sample.Views.Samples.PopupSampleView"
             x:DataType="vm:PopupSampleViewModel">
  <ScrollViewer>
    <StackPanel Spacing="16" Margin="0,0,0,24">
      <Border Classes="sample-card">
        <StackPanel Spacing="12">
          <TextBlock Text="基本弹出层" Classes="sample-title" />
          <TextBlock Text="基于 Avalonia Popup 的皮肤化封装，支持不同弹出方向。" Classes="sample-caption" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="切换弹出层" Command="{Binding TogglePopupCommand}" />
          </StackPanel>
          <Border Background="{DynamicResource Luna.Brush.Background.Component}"
                  CornerRadius="{DynamicResource Luna.Radius.Default}"
                  Padding="16"
                  IsVisible="{Binding IsPopupOpen}">
            <StackPanel Spacing="8">
              <TextBlock Text="弹出层内容" FontWeight="{DynamicResource Luna.FontWeight.SemiBold}" />
              <TextBlock Text="这是一个弹出层示例，展示弹出内容区域。" Classes="sample-caption" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <Border Classes="sample-card">
        <StackPanel Spacing="12">
          <TextBlock Text="不同弹出方向" Classes="sample-title" />
          <TextBlock Text="支持 Top / Bottom / Left / Right / Center 五种弹出方向。" Classes="sample-caption" />
          <WrapPanel Orientation="Horizontal" ItemWidth="160" ItemHeight="160">
            <Border Margin="8"
                    Background="{DynamicResource Luna.Brush.Background.Component}"
                    CornerRadius="{DynamicResource Luna.Radius.Default}"
                    BorderBrush="{DynamicResource Luna.Brush.Border.Default}"
                    BorderThickness="1">
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                <TextBlock Text="Top" HorizontalAlignment="Center"
                           Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                           FontSize="{DynamicResource Luna.FontSize.Body.Small}" />
                <Button Content="上方弹出" Command="{Binding ToggleTopCommand}" />
                <Border Background="{DynamicResource Luna.Brush.Brand.Light}"
                        CornerRadius="{DynamicResource Luna.Radius.Default}"
                        Padding="8,4"
                        IsVisible="{Binding IsTopOpen}">
                  <TextBlock Text="Top Popup" Foreground="{DynamicResource Luna.Brush.Brand}"
                             FontSize="{DynamicResource Luna.FontSize.Body.Small}" />
                </Border>
              </StackPanel>
            </Border>

            <Border Margin="8"
                    Background="{DynamicResource Luna.Brush.Background.Component}"
                    CornerRadius="{DynamicResource Luna.Radius.Default}"
                    BorderBrush="{DynamicResource Luna.Brush.Border.Default}"
                    BorderThickness="1">
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                <TextBlock Text="Bottom" HorizontalAlignment="Center"
                           Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                           FontSize="{DynamicResource Luna.FontSize.Body.Small}" />
                <Button Content="下方弹出" Command="{Binding ToggleBottomCommand}" />
                <Border Background="{DynamicResource Luna.Brush.Brand.Light}"
                        CornerRadius="{DynamicResource Luna.Radius.Default}"
                        Padding="8,4"
                        IsVisible="{Binding IsBottomOpen}">
                  <TextBlock Text="Bottom Popup" Foreground="{DynamicResource Luna.Brush.Brand}"
                             FontSize="{DynamicResource Luna.FontSize.Body.Small}" />
                </Border>
              </StackPanel>
            </Border>

            <Border Margin="8"
                    Background="{DynamicResource Luna.Brush.Background.Component}"
                    CornerRadius="{DynamicResource Luna.Radius.Default}"
                    BorderBrush="{DynamicResource Luna.Brush.Border.Default}"
                    BorderThickness="1">
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                <TextBlock Text="Left" HorizontalAlignment="Center"
                           Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                           FontSize="{DynamicResource Luna.FontSize.Body.Small}" />
                <Button Content="左侧弹出" Command="{Binding ToggleLeftCommand}" />
                <Border Background="{DynamicResource Luna.Brush.Brand.Light}"
                        CornerRadius="{DynamicResource Luna.Radius.Default}"
                        Padding="8,4"
                        IsVisible="{Binding IsLeftOpen}">
                  <TextBlock Text="Left Popup" Foreground="{DynamicResource Luna.Brush.Brand}"
                             FontSize="{DynamicResource Luna.FontSize.Body.Small}" />
                </Border>
              </StackPanel>
            </Border>

            <Border Margin="8"
                    Background="{DynamicResource Luna.Brush.Background.Component}"
                    CornerRadius="{DynamicResource Luna.Radius.Default}"
                    BorderBrush="{DynamicResource Luna.Brush.Border.Default}"
                    BorderThickness="1">
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                <TextBlock Text="Right" HorizontalAlignment="Center"
                           Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                           FontSize="{DynamicResource Luna.FontSize.Body.Small}" />
                <Button Content="右侧弹出" Command="{Binding ToggleRightCommand}" />
                <Border Background="{DynamicResource Luna.Brush.Brand.Light}"
                        CornerRadius="{DynamicResource Luna.Radius.Default}"
                        Padding="8,4"
                        IsVisible="{Binding IsRightOpen}">
                  <TextBlock Text="Right Popup" Foreground="{DynamicResource Luna.Brush.Brand}"
                             FontSize="{DynamicResource Luna.FontSize.Body.Small}" />
                </Border>
              </StackPanel>
            </Border>
          </WrapPanel>
        </StackPanel>
      </Border>

      <Border Classes="sample-card">
        <StackPanel Spacing="12">
          <TextBlock Text="居中弹出" Classes="sample-title" />
          <TextBlock Text="弹出层在触发元素正中显示。" Classes="sample-caption" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="居中弹出" Command="{Binding ToggleCenterCommand}" />
          </StackPanel>
          <Border Background="{DynamicResource Luna.Brush.Background.Component}"
                  CornerRadius="{DynamicResource Luna.Radius.Default}"
                  Padding="16"
                  IsVisible="{Binding IsCenterOpen}">
            <StackPanel Spacing="8">
              <TextBlock Text="Center Popup" FontWeight="{DynamicResource Luna.FontWeight.SemiBold}" />
              <TextBlock Text="居中弹出的弹出层内容示例。" Classes="sample-caption" />
              <Button Content="关闭" Command="{Binding ToggleCenterCommand}" Classes="text small" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
