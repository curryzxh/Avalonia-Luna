<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Luna.Desktop.Sample.ViewModels.Samples"
             x:Class="Luna.Desktop.Sample.Views.Samples.ProgressSampleView"
             x:DataType="vm:ProgressSampleViewModel">
  <StackPanel Spacing="16">
    <Border Classes="sample-card">
      <StackPanel Spacing="12" MaxWidth="560" HorizontalAlignment="Left">
        <TextBlock Text="线性进度" Classes="sample-title" />
        <ProgressBar Minimum="0" Maximum="100" Value="{Binding Percentage}" Height="8" />
        <Slider Minimum="0" Maximum="100" Value="{Binding Percentage}" />
      </StackPanel>
    </Border>

    <Border Classes="sample-card">
      <StackPanel Spacing="12" MaxWidth="560" HorizontalAlignment="Left">
        <TextBlock Text="状态进度" Classes="sample-title" />
        <StackPanel Spacing="8">
          <DockPanel>
            <TextBlock Text="成功" Width="48" VerticalAlignment="Center" Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
            <ProgressBar Minimum="0" Maximum="100" Value="{Binding SuccessPercentage}" Height="8" Foreground="{DynamicResource Luna.Brush.Success}" />
          </DockPanel>
          <DockPanel>
            <TextBlock Text="警告" Width="48" VerticalAlignment="Center" Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
            <ProgressBar Minimum="0" Maximum="100" Value="{Binding WarningPercentage}" Height="8" Foreground="{DynamicResource Luna.Brush.Warning}" />
          </DockPanel>
          <DockPanel>
            <TextBlock Text="错误" Width="48" VerticalAlignment="Center" Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
            <ProgressBar Minimum="0" Maximum="100" Value="{Binding ErrorPercentage}" Height="8" Foreground="{DynamicResource Luna.Brush.Error}" />
          </DockPanel>
        </StackPanel>
      </StackPanel>
    </Border>

    <Border Classes="sample-card">
      <StackPanel Spacing="12" MaxWidth="560" HorizontalAlignment="Left">
        <TextBlock Text="不确定进度" Classes="sample-title" />
        <ProgressBar IsIndeterminate="True" Height="8" />
      </StackPanel>
    </Border>

    <Border Classes="sample-card">
      <StackPanel Spacing="12" MaxWidth="560" HorizontalAlignment="Left">
        <TextBlock Text="不同尺寸" Classes="sample-title" />
        <StackPanel Spacing="8">
          <ProgressBar Minimum="0" Maximum="100" Value="50" Height="4" />
          <ProgressBar Minimum="0" Maximum="100" Value="50" Height="8" />
          <ProgressBar Minimum="0" Maximum="100" Value="50" Height="12" />
        </StackPanel>
      </StackPanel>
    </Border>

    <Border Classes="sample-card">
      <StackPanel Spacing="12" MaxWidth="560" HorizontalAlignment="Left">
        <TextBlock Text="带标签" Classes="sample-title" />
        <DockPanel>
          <TextBlock Text="{Binding Percentage, StringFormat='{}{0:F0}%'}" FontWeight="{DynamicResource Luna.FontWeight.SemiBold}" Foreground="{DynamicResource Luna.Brush.Text.Primary}" VerticalAlignment="Center" Margin="12,0,0,0" />
          <ProgressBar Minimum="0" Maximum="100" Value="{Binding Percentage}" Height="8" />
        </DockPanel>
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
