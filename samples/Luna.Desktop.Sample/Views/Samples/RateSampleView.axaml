<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Luna.Desktop.Sample.ViewModels.Samples"
             xmlns:controls="using:Luna.Desktop.Controls"
             x:Class="Luna.Desktop.Sample.Views.Samples.RateSampleView"
             x:DataType="vm:RateSampleViewModel">
  <StackPanel Spacing="16">
    <Border Classes="sample-card">
      <StackPanel Spacing="12" MaxWidth="400" HorizontalAlignment="Left">
        <TextBlock Text="基础评分" Classes="sample-title" />
        <controls:Rate Value="{Binding BasicRate, Mode=TwoWay}" />
        <TextBlock Text="{Binding BasicRate, StringFormat='当前评分：{0} 分'}" Classes="sample-caption" />
      </StackPanel>
    </Border>

    <Border Classes="sample-card">
      <StackPanel Spacing="12" MaxWidth="400" HorizontalAlignment="Left">
        <TextBlock Text="预设评分" Classes="sample-title" />
        <controls:Rate Value="{Binding PresetRate, Mode=TwoWay}" />
        <TextBlock Text="{Binding PresetRate, StringFormat='当前评分：{0} 分'}" Classes="sample-caption" />
      </StackPanel>
    </Border>

    <Border Classes="sample-card">
      <StackPanel Spacing="12" MaxWidth="400" HorizontalAlignment="Left">
        <TextBlock Text="自定义图标与大小" Classes="sample-title" />
        <controls:Rate Value="{Binding CustomRate, Mode=TwoWay}"
                       Character="♥"
                       IconSize="32"
                       Count="5"
                       AllowClear="True" />
        <TextBlock Text="{Binding CustomRate, StringFormat='当前评分：{0} 分'}" Classes="sample-caption" />
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
