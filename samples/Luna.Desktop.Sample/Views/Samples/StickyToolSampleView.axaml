<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Luna.Desktop.Sample.ViewModels.Samples"
             xmlns:controls="using:Luna.Desktop.Controls"
             x:Class="Luna.Desktop.Sample.Views.Samples.StickyToolSampleView"
             x:DataType="vm:StickyToolSampleViewModel">
  <StackPanel Spacing="16">
    <Border Classes="sample-card">
      <StackPanel Spacing="12">
        <TextBlock Text="固定工具栏" Classes="sample-title" />
        <TextBlock Text="StickyTool 固定在页面侧边，常用于放置快捷操作按钮。" Classes="sample-caption" />
        <Grid ColumnDefinitions="*,Auto">
          <Border Grid.Column="0" Height="200"
                  Background="{DynamicResource Luna.Brush.Background.Page}"
                  BorderBrush="{DynamicResource Luna.Brush.Border.Default}"
                  BorderThickness="1"
                  CornerRadius="{DynamicResource Luna.Radius.Default}">
            <TextBlock Text="页面内容区域" HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{DynamicResource Luna.Brush.Text.Placeholder}" />
          </Border>
          <controls:StickyTool Grid.Column="1" Position="Right" Offset="0" Margin="12,0,0,0">
            <StackPanel Spacing="4">
              <Button Content="📋" Classes="link" FontSize="20" />
              <Button Content="🔍" Classes="link" FontSize="20" />
              <Button Content="⚙️" Classes="link" FontSize="20" />
            </StackPanel>
          </controls:StickyTool>
        </Grid>
      </StackPanel>
    </Border>

    <Border Classes="sample-card">
      <StackPanel Spacing="12">
        <TextBlock Text="左侧定位" Classes="sample-title" />
        <Grid ColumnDefinitions="Auto,*">
          <controls:StickyTool Grid.Column="0" Position="Left" Offset="0" Margin="0,0,12,0">
            <StackPanel Spacing="4">
              <Button Content="🏠" Classes="link" FontSize="20" />
              <Button Content="📊" Classes="link" FontSize="20" />
            </StackPanel>
          </controls:StickyTool>
          <Border Grid.Column="1" Height="200"
                  Background="{DynamicResource Luna.Brush.Background.Page}"
                  BorderBrush="{DynamicResource Luna.Brush.Border.Default}"
                  BorderThickness="1"
                  CornerRadius="{DynamicResource Luna.Radius.Default}">
            <TextBlock Text="页面内容区域" HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{DynamicResource Luna.Brush.Text.Placeholder}" />
          </Border>
        </Grid>
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
