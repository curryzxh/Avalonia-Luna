<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Luna.Desktop.Sample.ViewModels.Samples"
             x:Class="Luna.Desktop.Sample.Views.Samples.SwitchSampleView"
             x:DataType="vm:SwitchSampleViewModel">
  <StackPanel Spacing="16">
    <Border Classes="sample-card">
      <StackPanel Spacing="12">
        <TextBlock Text="Switch 状态" Classes="sample-title" />
        <WrapPanel>
          <ToggleSwitch Content="实时预览" IsChecked="{Binding RealtimePreview, Mode=TwoWay}" Margin="0,0,24,8" />
          <ToggleSwitch Content="默认关闭" Margin="0,0,24,8" />
          <ToggleSwitch Content="加载占位" IsEnabled="False" IsChecked="True" Margin="0,0,24,8" />
          <ToggleSwitch Content="禁用状态" IsEnabled="False" Margin="0,0,24,8" />
        </WrapPanel>
      </StackPanel>
    </Border>

    <Border Classes="sample-card">
      <StackPanel Spacing="12">
        <TextBlock Text="不同尺寸 (Size)" Classes="sample-title" />
        <TextBlock Text="TDesign Switch 支持 small / medium / large 三种尺寸。当前通过 Classes 模拟不同尺寸。" Classes="sample-caption" />
        <WrapPanel VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,24,8" VerticalAlignment="Center">
            <TextBlock Text="Small" VerticalAlignment="Center" />
            <ToggleSwitch IsChecked="{Binding SmallSwitch, Mode=TwoWay}" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,24,8" VerticalAlignment="Center">
            <TextBlock Text="Medium" VerticalAlignment="Center" />
            <ToggleSwitch IsChecked="{Binding MediumSwitch, Mode=TwoWay}" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,24,8" VerticalAlignment="Center">
            <TextBlock Text="Large" VerticalAlignment="Center" />
            <ToggleSwitch IsChecked="{Binding LargeSwitch, Mode=TwoWay}" />
          </StackPanel>
        </WrapPanel>
      </StackPanel>
    </Border>

    <Border Classes="sample-card">
      <StackPanel Spacing="12">
        <TextBlock Text="带标签 (Label)" Classes="sample-title" />
        <WrapPanel>
          <ToggleSwitch OnContent="开" OffContent="关"
                        IsChecked="{Binding LabelSwitch, Mode=TwoWay}"
                        Margin="0,0,24,8" />
          <ToggleSwitch OnContent="已启用" OffContent="已禁用"
                        IsChecked="{Binding CustomLabelSwitch, Mode=TwoWay}"
                        Margin="0,0,24,8" />
        </WrapPanel>
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
