<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Luna.Desktop.Sample.ViewModels.Samples"
             x:Class="Luna.Desktop.Sample.Views.Samples.TypographySampleView"
             x:DataType="vm:TypographySampleViewModel">
  <StackPanel Spacing="16">
    <Border Classes="sample-card">
      <StackPanel Spacing="12">
        <TextBlock Text="标题级别" Classes="sample-title" />
        <TextBlock Text="使用 Classes=\"typography-h1~h6\" 切换标题级别，字号和字重自动匹配。" Classes="sample-caption" />
        <StackPanel Spacing="8">
          <TextBlock Text="H1 标题 — 28px SemiBold" Classes="typography-h1" />
          <TextBlock Text="H2 标题 — 20px SemiBold" Classes="typography-h2" />
          <TextBlock Text="H3 标题 — 16px SemiBold" Classes="typography-h3" />
          <TextBlock Text="H4 标题 — 14px SemiBold" Classes="typography-h4" />
          <TextBlock Text="H5 标题 — 12px SemiBold" Classes="typography-h5" />
          <TextBlock Text="H6 标题 — 12px Medium Secondary" Classes="typography-h6" />
        </StackPanel>
      </StackPanel>
    </Border>

    <Border Classes="sample-card">
      <StackPanel Spacing="12">
        <TextBlock Text="正文与辅助文字" Classes="sample-title" />
        <StackPanel Spacing="8">
          <TextBlock Text="Body 正文 — 14px Regular，用于主要段落文字。" Classes="typography-body" />
          <TextBlock Text="Body Small 小字 — 12px Regular，用于辅助说明。" Classes="typography-body-small" />
          <TextBlock Text="Caption 说明 — 12px Regular Secondary，用于次要注释。" Classes="typography-caption" />
        </StackPanel>
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
