<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Luna.Desktop.Sample.ViewModels.Samples"
             xmlns:controls="using:Luna.Desktop.Controls"
             x:Class="Luna.Desktop.Sample.Views.Samples.WatermarkSampleView"
             x:DataType="vm:WatermarkSampleViewModel">
  <ScrollViewer>
    <StackPanel Spacing="16" Margin="16">
      <Border Classes="sample-card">
        <StackPanel Spacing="12">
          <TextBlock Text="基本水印" Classes="sample-title" />
          <TextBlock Text="在内容区域上方叠加半透明重复水印文字。" Classes="sample-caption" />
          <controls:Watermark WatermarkText="{Binding WatermarkText}"
                              WatermarkOpacity="{Binding WatermarkOpacity}"
                              Rotate="{Binding WatermarkRotate}"
                              Gap="{Binding WatermarkGap}">
            <Border Width="500" Height="240"
                    Background="{DynamicResource Luna.Brush.Background.Container}"
                    BorderBrush="{DynamicResource Luna.Brush.Border.Default}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource Luna.Radius.Default}"
                    Padding="24">
              <StackPanel Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="这是受水印保护的内容区域"
                           FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                           Foreground="{DynamicResource Luna.Brush.Text.Primary}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="水印文字会叠加在内容上方，防止截图盗用。"
                           Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                           HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
          </controls:Watermark>
        </StackPanel>
      </Border>

      <Border Classes="sample-card">
        <StackPanel Spacing="12">
          <TextBlock Text="多行水印" Classes="sample-title" />
          <TextBlock Text="支持多行文字水印，使用换行符分隔。" Classes="sample-caption" />
          <controls:Watermark WatermarkText="{Binding MultiLineText}"
                              WatermarkOpacity="0.10"
                              Rotate="-22"
                              Gap="100">
            <Border Width="500" Height="240"
                    Background="{DynamicResource Luna.Brush.Background.Container}"
                    BorderBrush="{DynamicResource Luna.Brush.Border.Default}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource Luna.Radius.Default}"
                    Padding="24">
              <StackPanel Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="多行水印示例"
                           FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                           Foreground="{DynamicResource Luna.Brush.Text.Primary}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="水印内容可包含多行文本，适用于更丰富的标识需求。"
                           Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                           HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
          </controls:Watermark>
        </StackPanel>
      </Border>

      <Border Classes="sample-card">
        <StackPanel Spacing="12">
          <TextBlock Text="自定义参数" Classes="sample-title" />
          <TextBlock Text="通过下方控件实时调整水印参数。" Classes="sample-caption" />
          <controls:Watermark WatermarkText="{Binding WatermarkText}"
                              WatermarkOpacity="{Binding WatermarkOpacity}"
                              Rotate="{Binding WatermarkRotate}"
                              Gap="{Binding WatermarkGap}"
                              WatermarkFontSize="{Binding WatermarkFontSize}">
            <Border Width="500" Height="240"
                    Background="{DynamicResource Luna.Brush.Background.Container}"
                    BorderBrush="{DynamicResource Luna.Brush.Border.Default}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource Luna.Radius.Default}"
                    Padding="24">
              <StackPanel Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="实时调整下方参数，观察水印变化"
                           FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                           Foreground="{DynamicResource Luna.Brush.Text.Primary}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="修改透明度、旋转角度、间距和字号等参数。"
                           Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                           HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
          </controls:Watermark>

          <StackPanel Spacing="8">
            <TextBlock Text="水印文字" Classes="sample-caption" />
            <TextBox Text="{Binding WatermarkText}" />
          </StackPanel>
          <StackPanel Spacing="8">
            <TextBlock Text="{Binding WatermarkOpacity, StringFormat='{}透明度：{0:F2}'}" Classes="sample-caption" />
            <Slider Minimum="0.02" Maximum="0.5" Value="{Binding WatermarkOpacity}" />
          </StackPanel>
          <StackPanel Spacing="8">
            <TextBlock Text="{Binding WatermarkRotate, StringFormat='{}旋转角度：{0:F0}°'}" Classes="sample-caption" />
            <Slider Minimum="-90" Maximum="90" Value="{Binding WatermarkRotate}" />
          </StackPanel>
          <StackPanel Spacing="8">
            <TextBlock Text="{Binding WatermarkGap, StringFormat='{}间距：{0:F0}px'}" Classes="sample-caption" />
            <Slider Minimum="40" Maximum="300" Value="{Binding WatermarkGap}" />
          </StackPanel>
          <StackPanel Spacing="8">
            <TextBlock Text="{Binding WatermarkFontSize, StringFormat='{}字号：{0:F0}px'}" Classes="sample-caption" />
            <Slider Minimum="10" Maximum="36" Value="{Binding WatermarkFontSize}" />
          </StackPanel>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
