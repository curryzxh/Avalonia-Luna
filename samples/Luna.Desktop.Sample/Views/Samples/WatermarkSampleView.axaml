<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Luna.Desktop.Sample.ViewModels.Samples"
             xmlns:controls="using:Luna.Desktop.Controls"
             x:Class="Luna.Desktop.Sample.Views.Samples.WatermarkSampleView"
             x:DataType="vm:WatermarkSampleViewModel">
  <ScrollViewer>
    <StackPanel Spacing="16" Margin="0,0,0,24">
      <Border Classes="sample-card">
        <StackPanel Spacing="12">
          <TextBlock Text="基本水印" Classes="sample-title" />
          <TextBlock Text="在内容区域上方叠加半透明重复水印文字，防止截图盗用。" Classes="sample-caption" />
          <controls:Watermark WatermarkText="{Binding WatermarkText}"
                              WatermarkOpacity="{Binding WatermarkOpacity}"
                              Rotate="{Binding WatermarkRotate}"
                              Gap="{Binding WatermarkGap}"
                              WatermarkFontSize="{Binding WatermarkFontSize}"
                              IsScrolling="{Binding IsScrolling}">
            <Border Width="500" Height="240"
                    Background="{DynamicResource Luna.Brush.Background.Container}"
                    BorderBrush="{DynamicResource Luna.Brush.Border.Default}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource Luna.Radius.Default}"
                    Padding="24">
              <StackPanel Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="受水印保护的内容区域"
                           FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                           Foreground="{DynamicResource Luna.Brush.Text.Primary}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="水印文字会叠加在内容上方，防止截图盗用。"
                           Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                           HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
          </controls:Watermark>
        </StackPanel>
      </Border>

      <Border Classes="sample-card">
        <StackPanel Spacing="12">
          <TextBlock Text="自定义参数" Classes="sample-title" />
          <TextBlock Text="调整水印文字、透明度、旋转角度、间距等参数。" Classes="sample-caption" />
          <Grid ColumnDefinitions="Auto,200" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,4">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="水印文字" VerticalAlignment="Center" Margin="0,0,16,8" />
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding WatermarkText}" Margin="0,0,0,8" />

            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,8">
              <TextBlock.Text>
                <MultiBinding StringFormat='{}透明度：{0:F2}'>
                  <Binding Path="WatermarkOpacity" />
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
            <Slider Grid.Row="1" Grid.Column="1" Minimum="0.02" Maximum="0.5" Value="{Binding WatermarkOpacity}" Margin="0,0,0,8" />

            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,8">
              <TextBlock.Text>
                <MultiBinding StringFormat='{}旋转角度：{0:F0}°'>
                  <Binding Path="WatermarkRotate" />
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
            <Slider Grid.Row="2" Grid.Column="1" Minimum="-90" Maximum="90" Value="{Binding WatermarkRotate}" Margin="0,0,0,8" />

            <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,8">
              <TextBlock.Text>
                <MultiBinding StringFormat='{}间距：{0:F0}'>
                  <Binding Path="WatermarkGap" />
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
            <Slider Grid.Row="3" Grid.Column="1" Minimum="40" Maximum="300" Value="{Binding WatermarkGap}" Margin="0,0,0,8" />

            <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,8">
              <TextBlock.Text>
                <MultiBinding StringFormat='{}字号：{0:F0}'>
                  <Binding Path="WatermarkFontSize" />
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
            <Slider Grid.Row="4" Grid.Column="1" Minimum="10" Maximum="32" Value="{Binding WatermarkFontSize}" Margin="0,0,0,8" />

            <CheckBox Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Content="错位排列" IsChecked="{Binding IsScrolling}" />
          </Grid>
        </StackPanel>
      </Border>

      <Border Classes="sample-card">
        <StackPanel Spacing="12">
          <TextBlock Text="整页水印" Classes="sample-title" />
          <TextBlock Text="水印覆盖整个内容区域，适用于页面级水印场景。" Classes="sample-caption" />
          <controls:Watermark WatermarkText="Luna 内部文档"
                              WatermarkOpacity="0.08"
                              Rotate="-22"
                              Gap="160"
                              WatermarkFontSize="16">
            <Border Width="500" Height="300"
                    Background="{DynamicResource Luna.Brush.Background.Container}"
                    BorderBrush="{DynamicResource Luna.Brush.Border.Default}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource Luna.Radius.Default}"
                    Padding="24">
              <StackPanel Spacing="12">
                <TextBlock Text="项目需求文档 v2.0"
                           FontSize="{DynamicResource Luna.FontSize.Title.Large}"
                           FontWeight="{DynamicResource Luna.FontWeight.Bold}"
                           Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
                <TextBlock Text="本文档包含项目的核心需求描述和技术方案，仅供内部使用。"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
                <Border Height="1" Background="{DynamicResource Luna.Brush.Border.Default}" Margin="0,4" />
                <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource Luna.Brush.Text.Secondary}">
                  <TextBlock.Text>
                    1. 用户认证与授权模块&#x0a;2. 数据分析与报表系统&#x0a;3. 消息推送与通知中心&#x0a;4. 系统配置与权限管理
                  </TextBlock.Text>
                </TextBlock>
              </StackPanel>
            </Border>
          </controls:Watermark>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
