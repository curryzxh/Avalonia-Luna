<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:luna="https://github.com/curryzxh/Luna"
             xmlns:vm="using:Luna.Mobile.Sample.ViewModels"
             x:Class="Luna.Mobile.Sample.Views.BadgeDemoView"
             x:DataType="vm:BadgeDemoViewModel">
  <ScrollViewer Background="{DynamicResource Luna.Brush.Background.Page}">
    <StackPanel Spacing="24" Margin="0,0,0,28">
      <Border Background="{DynamicResource Luna.Brush.Background.Container}">
        <Grid ColumnDefinitions="56,*,56" MinHeight="56">
          <Button Classes="text"
                  Content="‹"
                  FontSize="34"
                  Padding="0"
                  Command="{Binding BackCommand}" />
          <TextBlock Grid.Column="1"
                     Text="Badge 徽标"
                     FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                     FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                     Foreground="{DynamicResource Luna.Brush.Text.Primary}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
        </Grid>
      </Border>

      <StackPanel Margin="16,0" Spacing="8">
        <TextBlock Text="Badge 徽标"
                   FontSize="{DynamicResource Luna.FontSize.Title.Large}"
                   FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                   Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
        <TextBlock Text="用于告知用户，该区域的状态变化或者待处理任务的数量。"
                   FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                   Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                   TextWrapping="Wrap" />
      </StackPanel>

      <StackPanel Spacing="28">
        <StackPanel Spacing="16">
          <TextBlock Text="01 组件类型"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                     FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                     Foreground="{DynamicResource Luna.Brush.Text.Primary}" />

          <StackPanel Spacing="12" Margin="16,0">
            <TextBlock Text="红点徽标"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
            <StackPanel Orientation="Horizontal" Spacing="48" Margin="0,12,0,0">
              <luna:Badge Dot="True">
                <TextBlock Text="消息"
                           FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                           Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
              </luna:Badge>
              <luna:Badge Dot="True" Offset="1,-1">
                <Border Width="24" Height="24"
                        CornerRadius="{DynamicResource Luna.Radius.Circle}"
                        Background="{DynamicResource Luna.Brush.Background.Component}" />
              </luna:Badge>
              <luna:Badge Dot="True" Offset="1,1">
                <Button Content="按钮" />
              </luna:Badge>
            </StackPanel>

            <TextBlock Text="数字徽标"
                       Margin="0,8,0,0"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
            <StackPanel Orientation="Horizontal" Spacing="48" Margin="0,12,0,0">
              <luna:Badge Count="8" Offset="4,0">
                <TextBlock Text="消息"
                           FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                           Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
              </luna:Badge>
              <luna:Badge Count="2" Offset="2,-2">
                <Border Width="24" Height="24"
                        CornerRadius="{DynamicResource Luna.Radius.Circle}"
                        Background="{DynamicResource Luna.Brush.Background.Component}" />
              </luna:Badge>
              <luna:Badge Count="8" Offset="2,2">
                <Button Content="按钮" />
              </luna:Badge>
            </StackPanel>

            <TextBlock Text="自定义徽标"
                       Margin="0,8,0,0"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
            <StackPanel Margin="0,12,0,0">
              <luna:Badge Count="NEW" Offset="0,2">
                <Button Content="按钮" />
              </luna:Badge>
            </StackPanel>
          </StackPanel>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="02 组件样式"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                     FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                     Foreground="{DynamicResource Luna.Brush.Text.Primary}" />

          <StackPanel Spacing="12" Margin="16,0">
            <TextBlock Text="圆形徽标"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
            <luna:Badge Count="2" Offset="2,-2">
              <Border Width="24" Height="24"
                      CornerRadius="{DynamicResource Luna.Radius.Circle}"
                      Background="{DynamicResource Luna.Brush.Background.Component}" />
            </luna:Badge>

            <TextBlock Text="方形徽标"
                       Margin="0,12,0,0"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
            <luna:Badge Count="2" Shape="Square" Offset="1,-2">
              <Border Width="24" Height="24"
                      CornerRadius="{DynamicResource Luna.Radius.Small}"
                      Background="{DynamicResource Luna.Brush.Background.Component}" />
            </luna:Badge>

            <TextBlock Text="气泡徽标"
                       Margin="0,12,0,0"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
            <luna:Badge Count="领积分" Shape="Bubble">
              <Button Content="按钮" />
            </luna:Badge>

            <TextBlock Text="角标（占位）"
                       Margin="0,12,0,0"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
            <TextBlock Text="占位：ribbon / ribbon-left 暂未实现"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Placeholder}" />

            <TextBlock Text="三角角标（占位）"
                       Margin="0,12,0,0"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
            <TextBlock Text="占位：triangle-left / triangle-right 暂未实现"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Placeholder}" />
          </StackPanel>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="03 组件尺寸"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                     FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                     Foreground="{DynamicResource Luna.Brush.Text.Primary}" />

          <StackPanel Spacing="12" Margin="16,0">
            <TextBlock Text="Large"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
            <luna:Badge Count="8" Offset="7,7">
              <Border Width="56" Height="56"
                      CornerRadius="{DynamicResource Luna.Radius.Circle}"
                      Background="{DynamicResource Luna.Brush.Background.Component}" />
            </luna:Badge>

            <TextBlock Text="Medium"
                       Margin="0,12,0,0"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
            <luna:Badge Count="8" Offset="5,5">
              <Border Width="40" Height="40"
                      CornerRadius="{DynamicResource Luna.Radius.Circle}"
                      Background="{DynamicResource Luna.Brush.Background.Component}" />
            </luna:Badge>
          </StackPanel>
        </StackPanel>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
