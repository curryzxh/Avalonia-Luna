<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Luna.Mobile.Sample.Views.ButtonDemoView">
  <ScrollViewer Background="{DynamicResource Luna.Brush.Background.Page}">
    <StackPanel Spacing="24" Margin="0,0,0,28">
      <Border Background="{DynamicResource Luna.Brush.Background.Container}">
        <Grid ColumnDefinitions="56,*,56" MinHeight="56">
          <Button Classes="text"
                  Content="‹"
                  FontSize="34"
                  Padding="0"
                  Click="OnBackClick" />
          <TextBlock Grid.Column="1"
                     Text="Button 按钮"
                     FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                     FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                     Foreground="{DynamicResource Luna.Brush.Text.Primary}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
        </Grid>
      </Border>

      <StackPanel Margin="16,0" Spacing="8">
        <TextBlock Text="Button 按钮"
                   FontSize="{DynamicResource Luna.FontSize.Title.Large}"
                   FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                   Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
        <TextBlock Text="按钮用于开启一个闭环的操作任务，如“删除”对象、“购买”商品等。"
                   FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                   Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                   TextWrapping="Wrap" />
      </StackPanel>

      <StackPanel Spacing="28">
        <StackPanel Spacing="16">
          <StackPanel Margin="16,0" Spacing="4">
            <TextBlock Text="01 组件类型"
                       FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                       FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                       Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
            <TextBlock Text="基础按钮"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          </StackPanel>

          <StackPanel Spacing="16">
            <StackPanel Orientation="Horizontal" Spacing="16" Margin="16,0">
              <Button Classes="primary large" Content="填充按钮" />
              <Button Classes="light large" Content="填充按钮" />
              <Button Classes="large" Content="填充按钮" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="16" Margin="16,0">
              <Button Classes="primary outline large" Content="描边按钮" />
              <Button Classes="primary text large" Content="文字按钮" />
            </StackPanel>
          </StackPanel>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="图标按钮"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                     Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          <StackPanel Orientation="Horizontal" Spacing="16" Margin="16,0">
            <Button Classes="primary large">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Path Width="18" Height="18" Data="M3 3H10V10H3V3Z M14 14H21V21H14V14Z M3 14H10V21H3V14Z M21 6.5A3.5 3.5 0 1 1 14 6.5A3.5 3.5 0 1 1 21 6.5Z" Stroke="{DynamicResource Luna.Brush.Text.Anti}" StrokeThickness="2" Stretch="Uniform" />
                <TextBlock Text="填充按钮" />
              </StackPanel>
            </Button>
            <Button Classes="primary square large">
              <Path Width="22" Height="22" Data="M3 3H10V10H3V3Z M14 14H21V21H14V14Z M3 14H10V21H3V14Z M21 6.5A3.5 3.5 0 1 1 14 6.5A3.5 3.5 0 1 1 21 6.5Z" Stroke="{DynamicResource Luna.Brush.Text.Anti}" StrokeThickness="2" Stretch="Uniform" />
            </Button>
            <Button Classes="primary large" Content="加载中" />
          </StackPanel>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="幽灵按钮"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                     Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          <Border Margin="0" Padding="16" Background="#181818">
            <StackPanel Orientation="Horizontal" Spacing="16">
              <Button Classes="primary ghost large" Content="幽灵按钮" />
              <Button Classes="danger ghost large" Content="幽灵按钮" />
              <Button Classes="ghost large" Content="幽灵按钮" />
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="组合按钮"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                     Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          <Grid Margin="16,0" ColumnDefinitions="*,*" ColumnSpacing="16">
            <Button Classes="light large" Content="填充按钮" />
            <Button Grid.Column="1" Classes="primary large" Content="填充按钮" />
          </Grid>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="通栏按钮"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                     Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          <Button Margin="16,0" Classes="primary large" HorizontalAlignment="Stretch" Content="填充按钮" />
        </StackPanel>

        <StackPanel Spacing="16">
          <StackPanel Margin="16,0" Spacing="4">
            <TextBlock Text="02 组件状态"
                       FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                       FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                       Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
            <TextBlock Text="按钮禁用态"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          </StackPanel>
          <StackPanel Spacing="16">
            <StackPanel Orientation="Horizontal" Spacing="16" Margin="16,0">
              <Button Classes="primary large" Content="填充按钮" IsEnabled="False" />
              <Button Classes="light large" Content="填充按钮" IsEnabled="False" />
              <Button Classes="large" Content="填充按钮" IsEnabled="False" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="16" Margin="16,0">
              <Button Classes="primary outline large" Content="描边按钮" IsEnabled="False" />
              <Button Classes="primary text large" Content="文字按钮" IsEnabled="False" />
            </StackPanel>
          </StackPanel>
        </StackPanel>

        <StackPanel Spacing="16">
          <StackPanel Margin="16,0" Spacing="4">
            <TextBlock Text="03 组件样式"
                       FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                       FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                       Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
            <TextBlock Text="按钮尺寸"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0">
            <Button Classes="primary large" Content="按钮48" />
            <Button Classes="primary" Content="按钮40" />
            <Button Classes="primary small" Content="按钮32" />
            <Button Classes="primary extra-small" Content="按钮28" />
          </StackPanel>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="按钮形状"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                     Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0">
            <Button Classes="primary large" Content="填充按钮" />
            <Button Classes="primary square large">
              <Path Width="22" Height="22" Data="M3 3H10V10H3V3Z M14 14H21V21H14V14Z M3 14H10V21H3V14Z M21 6.5A3.5 3.5 0 1 1 14 6.5A3.5 3.5 0 1 1 21 6.5Z" Stroke="{DynamicResource Luna.Brush.Text.Anti}" StrokeThickness="2" Stretch="Uniform" />
            </Button>
            <Button Classes="primary round large" Content="填充按钮" />
            <Button Classes="primary circle large">
              <Path Width="22" Height="22" Data="M3 3H10V10H3V3Z M14 14H21V21H14V14Z M3 14H10V21H3V14Z M21 6.5A3.5 3.5 0 1 1 14 6.5A3.5 3.5 0 1 1 21 6.5Z" Stroke="{DynamicResource Luna.Brush.Text.Anti}" StrokeThickness="2" Stretch="Uniform" />
            </Button>
          </StackPanel>
          <Button Margin="16,0" Classes="primary large rectangle" HorizontalAlignment="Stretch" Content="填充按钮" />
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="按钮主题"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                     Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <StackPanel Spacing="16" Margin="16,0">
              <StackPanel Orientation="Horizontal" Spacing="16">
                <Button Classes="large" Content="填充按钮" />
                <Button Classes="outline large" Content="描边按钮" />
                <Button Classes="text large" Content="文字按钮" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="16">
                <Button Classes="primary large" Content="填充按钮" />
                <Button Classes="primary outline large" Content="描边按钮" />
                <Button Classes="primary text large" Content="文字按钮" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="16">
                <Button Classes="danger large" Content="填充按钮" />
                <Button Classes="danger outline large" Content="描边按钮" />
                <Button Classes="danger text large" Content="文字按钮" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="16">
                <Button Classes="light large" Content="填充按钮" />
                <Button Classes="light outline large" Content="描边按钮" />
                <Button Classes="light text large" Content="文字按钮" />
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </StackPanel>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
