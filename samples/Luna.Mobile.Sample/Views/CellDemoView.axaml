<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:luna="https://github.com/curryzxh/Luna"
             xmlns:vm="using:Luna.Mobile.Sample.ViewModels"
             x:Class="Luna.Mobile.Sample.Views.CellDemoView"
             x:DataType="vm:CellDemoViewModel">
  <ScrollViewer Background="{DynamicResource Luna.Brush.Background.Page}">
    <StackPanel Spacing="24" Margin="0,0,0,28">
      
      <StackPanel Margin="16,0" Spacing="8">
        <TextBlock Text="Cell 单元格"
                   FontSize="{DynamicResource Luna.FontSize.Title.Large}"
                   FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                   Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
        <TextBlock Text="用于承载各类信息展示，并提供导航入口。"
                   FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                   Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                   TextWrapping="Wrap" />
      </StackPanel>

      <StackPanel Spacing="28">
        <StackPanel Spacing="16">
          <TextBlock Text="01 组件类型"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                     FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                     Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
          <luna:CellGroup Title="基础用法">
            <StackPanel>
              <luna:Cell Title="单元格" RightText="内容" />
              <luna:Cell Title="带描述单元格" Description="描述文字" RightText="内容" />
              <luna:Cell Title="带图标单元格" RightText="内容">
                <luna:Cell.LeftContent>
                  <Border Width="24"
                          Height="24"
                          CornerRadius="{DynamicResource Luna.Radius.Circle}"
                          Background="{DynamicResource Luna.Brush.Background.Component}" />
                </luna:Cell.LeftContent>
              </luna:Cell>
            </StackPanel>
          </luna:CellGroup>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="02 状态"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                     FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                     Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
          <luna:CellGroup Title="禁用状态">
            <StackPanel>
              <luna:Cell Title="禁用单元格" RightText="内容" IsEnabled="False" />
              <luna:Cell Title="禁用带描述" Description="描述文字" RightText="内容" IsEnabled="False" />
            </StackPanel>
          </luna:CellGroup>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="03 组件样式"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                     FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                     Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
          <luna:CellGroup Title="右侧内容">
            <StackPanel>
              <luna:Cell Title="带开关"
                             ShowArrow="False">
                <luna:Cell.RightContent>
                  <ToggleSwitch IsChecked="True" />
                </luna:Cell.RightContent>
              </luna:Cell>
              <luna:Cell Title="隐藏箭头"
                             RightText="内容"
                             ShowArrow="False" />
            </StackPanel>
          </luna:CellGroup>
        </StackPanel>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
