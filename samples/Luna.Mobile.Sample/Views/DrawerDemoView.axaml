<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:luna="https://github.com/curryzxh/Luna"
             xmlns:vm="using:Luna.Mobile.Sample.ViewModels"
             x:Class="Luna.Mobile.Sample.Views.DrawerDemoView"
             x:DataType="vm:DrawerDemoViewModel">
  <Grid>
    <ScrollViewer Background="{DynamicResource Luna.Brush.Background.Page}">
      <StackPanel Spacing="24" Margin="0,0,0,28">
        <Border Background="{DynamicResource Luna.Brush.Background.Container}">
          <Grid ColumnDefinitions="56,*,56" MinHeight="56">
            <Button Classes="text"
                    Content="‹"
                    FontSize="34"
                    Padding="0"
                    Command="{Binding BackCommand}" />
            <TextBlock Grid.Column="1"
                       Text="Drawer 抽屉"
                       FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                       FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                       Foreground="{DynamicResource Luna.Brush.Text.Primary}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Grid>
        </Border>

        <StackPanel Margin="16,0" Spacing="8">
          <TextBlock Text="Drawer 抽屉"
                     FontSize="{DynamicResource Luna.FontSize.Title.Large}"
                     FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                     Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
          <TextBlock Text="用于在页面两侧滑出内容面板，提供导航或补充信息。"
                     FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                     Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                     TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Spacing="28">
          <StackPanel Spacing="16">
            <StackPanel Margin="16,0" Spacing="4">
              <TextBlock Text="01 类型"
                         FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                         FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                         Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
              <TextBlock Text="左右抽屉"
                         FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                         Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
            </StackPanel>
            <StackPanel Margin="16,0" Spacing="16">
              <Button Classes="primary outline large"
                      HorizontalAlignment="Stretch"
                      Content="打开左侧抽屉"
                      Click="OnOpenLeftClick" />
              <Button Classes="primary outline large"
                      HorizontalAlignment="Stretch"
                      Content="打开右侧抽屉"
                      Click="OnOpenRightClick" />
            </StackPanel>
          </StackPanel>

          <StackPanel Spacing="16">
            <StackPanel Margin="16,0" Spacing="4">
              <TextBlock Text="02 组件状态"
                         FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                         FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                         Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
              <TextBlock Text="遮罩与关闭行为"
                         FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                         Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
            </StackPanel>
            <StackPanel Margin="16,0" Spacing="16">
              <Button Classes="primary outline large"
                      HorizontalAlignment="Stretch"
                      Content="无遮罩"
                      Click="OnOpenNoOverlayClick" />
              <Button Classes="primary outline large"
                      HorizontalAlignment="Stretch"
                      Content="遮罩不可点击关闭"
                      Click="OnOpenNoOverlayCloseClick" />
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </StackPanel>
    </ScrollViewer>

    <luna:DrawerHost Name="DrawerHost"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch" />
  </Grid>
</UserControl>
