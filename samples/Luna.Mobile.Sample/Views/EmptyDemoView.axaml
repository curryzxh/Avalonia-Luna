<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:luna="https://github.com/curryzxh/Luna"
             xmlns:vm="using:Luna.Mobile.Sample.ViewModels"
             x:Class="Luna.Mobile.Sample.Views.EmptyDemoView"
             x:DataType="vm:EmptyDemoViewModel">
  <ScrollViewer Background="{DynamicResource Luna.Brush.Background.Page}">
    <StackPanel Spacing="24" Margin="0,0,0,28">
      <Border Background="{DynamicResource Luna.Brush.Background.Container}">
        <Grid ColumnDefinitions="56,*,56" MinHeight="56">
          <Button Classes="text"
                  Content="‹"
                  FontSize="34"
                  Padding="0"
                  Command="{Binding BackCommand}" />
          <TextBlock Grid.Column="1"
                     Text="Empty 空状态"
                     FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                     FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                     Foreground="{DynamicResource Luna.Brush.Text.Primary}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
        </Grid>
      </Border>

      <StackPanel Margin="16,0" Spacing="8">
        <TextBlock Text="Empty 空状态"
                   FontSize="{DynamicResource Luna.FontSize.Title.Large}"
                   FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                   Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
        <TextBlock Text="用于在列表为空、无搜索结果或暂无数据时，向用户传达信息并引导下一步操作。"
                   FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                   Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                   TextWrapping="Wrap" />
      </StackPanel>

      <StackPanel Spacing="28">
        <StackPanel Spacing="16">
          <TextBlock Text="01 组件类型"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                     FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                     Foreground="{DynamicResource Luna.Brush.Text.Primary}" />

          <StackPanel Spacing="12" Margin="16,0">
            <TextBlock Text="基础空状态"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
            <Border Background="{DynamicResource Luna.Brush.Background.Container}"
                    CornerRadius="{DynamicResource Luna.Radius.Default}"
                    Height="280">
              <luna:Empty Title="暂无数据"
                              Description="当前列表为空，稍后再试。"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
            </Border>

            <TextBlock Text="带操作按钮"
                       Margin="0,12,0,0"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
            <Border Background="{DynamicResource Luna.Brush.Background.Container}"
                    CornerRadius="{DynamicResource Luna.Radius.Default}"
                    Height="300">
              <luna:Empty Title="暂无结果"
                              Description="尝试调整筛选条件或重新搜索。"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                <luna:Empty.Action>
                  <Button Classes="primary large"
                          HorizontalAlignment="Stretch"
                          Content="刷新" />
                </luna:Empty.Action>
              </luna:Empty>
            </Border>
          </StackPanel>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="02 组件样式"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                     FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                     Foreground="{DynamicResource Luna.Brush.Text.Primary}" />

          <StackPanel Spacing="12" Margin="16,0">
            <TextBlock Text="自定义图标"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
            <Border Background="{DynamicResource Luna.Brush.Background.Container}"
                    CornerRadius="{DynamicResource Luna.Radius.Default}"
                    Height="280">
              <luna:Empty Title="网络异常"
                              Description="请检查网络设置后重试。"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                <luna:Empty.Icon>
                  <Border Width="120"
                          Height="120"
                          Background="{DynamicResource Luna.Brush.Background.Component}"
                          CornerRadius="{DynamicResource Luna.Radius.Default}">
                    <TextBlock Text="!"
                               FontSize="44"
                               Foreground="{DynamicResource Luna.Brush.Warning}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                  </Border>
                </luna:Empty.Icon>
              </luna:Empty>
            </Border>
          </StackPanel>
        </StackPanel>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
