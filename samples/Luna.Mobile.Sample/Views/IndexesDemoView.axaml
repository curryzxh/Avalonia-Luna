<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:luna="https://github.com/curryzxh/Luna"
             xmlns:vm="using:Luna.Mobile.Sample.ViewModels"
             x:Class="Luna.Mobile.Sample.Views.IndexesDemoView"
             x:DataType="vm:IndexesDemoViewModel">
  <ScrollViewer Background="{DynamicResource Luna.Brush.Background.Page}">
    <StackPanel Spacing="24" Margin="0,0,0,28">
      <Border Background="{DynamicResource Luna.Brush.Background.Container}">
        <Grid ColumnDefinitions="56,*,56" MinHeight="56">
          <Button Classes="text"
                  Content="‹"
                  FontSize="34"
                  Padding="0"
                  Command="{Binding BackCommand}" />
          <TextBlock Grid.Column="1"
                     Text="Indexes 索引"
                     FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                     FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                     Foreground="{DynamicResource Luna.Brush.Text.Primary}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
        </Grid>
      </Border>

      <StackPanel Margin="16,0" Spacing="8">
        <TextBlock Text="Indexes 索引"
                   FontSize="{DynamicResource Luna.FontSize.Title.Large}"
                   FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                   Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
        <TextBlock Text="用于页面中信息快速检索，可以根据右侧目录快速找到所需内容。"
                   FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                   Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                   TextWrapping="Wrap" />
      </StackPanel>

      <StackPanel Spacing="28">
        <StackPanel Spacing="16">
          <StackPanel Margin="16,0" Spacing="4">
            <TextBlock Text="01 基础用法"
                       FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                       FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                       Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
            <TextBlock Text="右侧索引栏支持点击跳转，滚动时自动联动高亮当前分组。"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                       TextWrapping="Wrap" />
          </StackPanel>
          <Border Background="{DynamicResource Luna.Brush.Background.Container}"
                  Padding="12"
                  Height="520">
            <luna:Indexes Sticky="True">
              <StackPanel Spacing="0">
                <luna:IndexesAnchor Index="A" />
                <luna:CellGroup>
                  <StackPanel>
                    <luna:Cell Title="阿坝" />
                    <luna:Cell Title="阿拉善" />
                    <luna:Cell Title="阿里" />
                    <luna:Cell Title="安康" />
                    <luna:Cell Title="安庆" />
                  </StackPanel>
                </luna:CellGroup>

                <luna:IndexesAnchor Index="B" />
                <luna:CellGroup>
                  <StackPanel>
                    <luna:Cell Title="北京" />
                    <luna:Cell Title="白银" />
                    <luna:Cell Title="保定" />
                    <luna:Cell Title="宝鸡" />
                    <luna:Cell Title="包头" />
                  </StackPanel>
                </luna:CellGroup>

                <luna:IndexesAnchor Index="C" />
                <luna:CellGroup>
                  <StackPanel>
                    <luna:Cell Title="重庆" />
                    <luna:Cell Title="成都" />
                    <luna:Cell Title="长沙" />
                    <luna:Cell Title="长春" />
                    <luna:Cell Title="沧州" />
                  </StackPanel>
                </luna:CellGroup>

                <luna:IndexesAnchor Index="D" />
                <luna:CellGroup>
                  <StackPanel>
                    <luna:Cell Title="大连" />
                    <luna:Cell Title="东莞" />
                    <luna:Cell Title="大理" />
                    <luna:Cell Title="大庆" />
                    <luna:Cell Title="德州" />
                  </StackPanel>
                </luna:CellGroup>

                <luna:IndexesAnchor Index="E" />
                <luna:CellGroup>
                  <StackPanel>
                    <luna:Cell Title="鄂尔多斯" />
                    <luna:Cell Title="恩施" />
                    <luna:Cell Title="鄂州" />
                  </StackPanel>
                </luna:CellGroup>

                <luna:IndexesAnchor Index="F" />
                <luna:CellGroup>
                  <StackPanel>
                    <luna:Cell Title="福州" />
                    <luna:Cell Title="防城港" />
                    <luna:Cell Title="佛山" />
                    <luna:Cell Title="阜阳" />
                  </StackPanel>
                </luna:CellGroup>

                <luna:IndexesAnchor Index="G" />
                <luna:CellGroup>
                  <StackPanel>
                    <luna:Cell Title="广州" />
                    <luna:Cell Title="桂林" />
                    <luna:Cell Title="贵阳" />
                    <luna:Cell Title="赣州" />
                  </StackPanel>
                </luna:CellGroup>

                <luna:IndexesAnchor Index="J" />
                <luna:CellGroup>
                  <StackPanel>
                    <luna:Cell Title="揭阳" />
                    <luna:Cell Title="吉林" />
                    <luna:Cell Title="嘉兴" />
                    <luna:Cell Title="济南" />
                  </StackPanel>
                </luna:CellGroup>

                <luna:IndexesAnchor Index="K" />
                <luna:CellGroup>
                  <StackPanel>
                    <luna:Cell Title="昆明" />
                    <luna:Cell Title="开封" />
                    <luna:Cell Title="康定" />
                    <luna:Cell Title="喀什" />
                  </StackPanel>
                </luna:CellGroup>
              </StackPanel>
            </luna:Indexes>
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <StackPanel Margin="16,0" Spacing="4">
            <TextBlock Text="02 组件状态"
                       FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                       FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                       Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
            <TextBlock Text="关闭吸顶后，分组标题跟随内容滚动。"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          </StackPanel>
          <Border Background="{DynamicResource Luna.Brush.Background.Container}"
                  Padding="12"
                  Height="360">
            <luna:Indexes Sticky="False">
              <StackPanel Spacing="0">
                <luna:IndexesAnchor Index="L" />
                <luna:CellGroup>
                  <StackPanel>
                    <luna:Cell Title="廊坊" />
                    <luna:Cell Title="兰州" />
                    <luna:Cell Title="拉萨" />
                  </StackPanel>
                </luna:CellGroup>

                <luna:IndexesAnchor Index="M" />
                <luna:CellGroup>
                  <StackPanel>
                    <luna:Cell Title="绵阳" />
                    <luna:Cell Title="茂名" />
                    <luna:Cell Title="眉山" />
                  </StackPanel>
                </luna:CellGroup>

                <luna:IndexesAnchor Index="N" />
                <luna:CellGroup>
                  <StackPanel>
                    <luna:Cell Title="南京" />
                    <luna:Cell Title="南宁" />
                    <luna:Cell Title="南昌" />
                  </StackPanel>
                </luna:CellGroup>

                <luna:IndexesAnchor Index="S" />
                <luna:CellGroup>
                  <StackPanel>
                    <luna:Cell Title="上海" />
                    <luna:Cell Title="深圳" />
                    <luna:Cell Title="沈阳" />
                  </StackPanel>
                </luna:CellGroup>
              </StackPanel>
            </luna:Indexes>
          </Border>
        </StackPanel>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
