<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Luna.Mobile.Sample.Views.LinkDemoView">
  <UserControl.Styles>
    <Style Selector="Border.link-demo-block">
      <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.Container}" />
      <Setter Property="Margin" Value="16,0" />
      <Setter Property="Padding" Value="16,0" />
      <Setter Property="MinHeight" Value="48" />
    </Style>

    <Style Selector="Path.link-demo-icon">
      <Setter Property="Width" Value="12" />
      <Setter Property="Height" Value="12" />
      <Setter Property="StrokeThickness" Value="1.6" />
      <Setter Property="StrokeLineCap" Value="Round" />
      <Setter Property="Stroke" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=HyperlinkButton}}" />
      <Setter Property="Stretch" Value="Uniform" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
  </UserControl.Styles>
  <ScrollViewer Background="{DynamicResource Luna.Brush.Background.Page}">
    <StackPanel Spacing="24" Margin="0,0,0,28">
      <StackPanel Margin="16,0" Spacing="8">
        <TextBlock Text="Link 链接"
                   FontSize="{DynamicResource Luna.FontSize.Title.Large}"
                   FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                   Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
        <TextBlock Text="文字超链接用于跳转一个新页面，如当前项目跳转，友情链接等。"
                   FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                   Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                   TextWrapping="Wrap" />
      </StackPanel>

      <StackPanel Spacing="28">
        <StackPanel Spacing="16">
          <StackPanel Margin="16,0" Spacing="4">
            <TextBlock Text="01 组件类型"
                       FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                       FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                       Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
            <TextBlock Text="基础文字链接"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          </StackPanel>

          <Border Classes="link-demo-block">
            <StackPanel Orientation="Horizontal"
                        Spacing="32"
                        VerticalAlignment="Center">
              <HyperlinkButton Classes="primary small" Content="跳转链接" />
              <HyperlinkButton Classes="small" Content="跳转链接" />
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="下划线文字链接"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                     Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />

          <Border Classes="link-demo-block">
            <StackPanel Orientation="Horizontal"
                        Spacing="32"
                        VerticalAlignment="Center">
              <HyperlinkButton Classes="primary small underline" Content="跳转链接" />
              <HyperlinkButton Classes="small underline" Content="跳转链接" />
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="前置图标文字链接"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                     Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />

          <Border Classes="link-demo-block">
            <StackPanel Orientation="Horizontal"
                        Spacing="32"
                        VerticalAlignment="Center">
              <HyperlinkButton Classes="primary small">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <Path Classes="link-demo-icon"
                        Data="M5 3H19V17H5V3Z M8 7H16 M8 10H16 M8 13H13" />
                  <TextBlock Text="跳转链接" />
                </StackPanel>
              </HyperlinkButton>

              <HyperlinkButton Classes="small">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <Path Classes="link-demo-icon"
                        Data="M5 3H19V17H5V3Z M8 7H16 M8 10H16 M8 13H13" />
                  <TextBlock Text="跳转链接" />
                </StackPanel>
              </HyperlinkButton>
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="后置图标文字链接"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                     Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />

          <Border Classes="link-demo-block">
            <StackPanel Orientation="Horizontal"
                        Spacing="32"
                        VerticalAlignment="Center">
              <HyperlinkButton Classes="primary small underline">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="跳转链接" />
                  <Path Classes="link-demo-icon"
                        Data="M6 6H18V18 M7 17L17 7" />
                </StackPanel>
              </HyperlinkButton>

              <HyperlinkButton Classes="small underline">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="跳转链接" />
                  <Path Classes="link-demo-icon"
                        Data="M6 6H18V18 M7 17L17 7" />
                </StackPanel>
              </HyperlinkButton>
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <StackPanel Margin="16,0" Spacing="4">
            <TextBlock Text="02 组件状态"
                       FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                       FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                       Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
            <TextBlock Text="不同主题"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          </StackPanel>

          <Border Classes="link-demo-block">
            <StackPanel Spacing="16">
              <StackPanel Orientation="Horizontal" Spacing="28">
                <HyperlinkButton Classes="primary small">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="跳转链接" />
                    <Path Classes="link-demo-icon"
                          Data="M6 6H18V18 M7 17L17 7" />
                  </StackPanel>
                </HyperlinkButton>
                <HyperlinkButton Classes="small">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="跳转链接" />
                    <Path Classes="link-demo-icon"
                          Data="M6 6H18V18 M7 17L17 7" />
                  </StackPanel>
                </HyperlinkButton>
                <HyperlinkButton Classes="danger small">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="跳转链接" />
                    <Path Classes="link-demo-icon"
                          Data="M6 6H18V18 M7 17L17 7" />
                  </StackPanel>
                </HyperlinkButton>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="28">
                <HyperlinkButton Classes="success small">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="跳转链接" />
                    <Path Classes="link-demo-icon"
                          Data="M6 6H18V18 M7 17L17 7" />
                  </StackPanel>
                </HyperlinkButton>
                <HyperlinkButton Classes="warning small">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="跳转链接" />
                    <Path Classes="link-demo-icon"
                          Data="M6 6H18V18 M7 17L17 7" />
                  </StackPanel>
                </HyperlinkButton>
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="禁用状态"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                     Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />

          <Border Classes="link-demo-block">
            <StackPanel Spacing="16">
              <StackPanel Orientation="Horizontal" Spacing="28">
                <HyperlinkButton Classes="primary small" IsEnabled="False">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="跳转链接" />
                    <Path Classes="link-demo-icon"
                          Data="M6 6H18V18 M7 17L17 7" />
                  </StackPanel>
                </HyperlinkButton>
                <HyperlinkButton Classes="small" IsEnabled="False">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="跳转链接" />
                    <Path Classes="link-demo-icon"
                          Data="M6 6H18V18 M7 17L17 7" />
                  </StackPanel>
                </HyperlinkButton>
                <HyperlinkButton Classes="danger small" IsEnabled="False">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="跳转链接" />
                    <Path Classes="link-demo-icon"
                          Data="M6 6H18V18 M7 17L17 7" />
                  </StackPanel>
                </HyperlinkButton>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="28">
                <HyperlinkButton Classes="success small" IsEnabled="False">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="跳转链接" />
                    <Path Classes="link-demo-icon"
                          Data="M6 6H18V18 M7 17L17 7" />
                  </StackPanel>
                </HyperlinkButton>
                <HyperlinkButton Classes="warning small" IsEnabled="False">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="跳转链接" />
                    <Path Classes="link-demo-icon"
                          Data="M6 6H18V18 M7 17L17 7" />
                  </StackPanel>
                </HyperlinkButton>
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <StackPanel Margin="16,0" Spacing="4">
            <TextBlock Text="03 组件样式"
                       FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                       FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                       Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
            <TextBlock Text="链接尺寸"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          </StackPanel>

          <Border Classes="link-demo-block">
            <StackPanel Orientation="Horizontal"
                        Spacing="28"
                        VerticalAlignment="Center">
              <HyperlinkButton Classes="primary small">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="S号链接" />
                  <Path Classes="link-demo-icon"
                        Data="M6 6H18V18 M7 17L17 7" />
                </StackPanel>
              </HyperlinkButton>

              <HyperlinkButton Classes="primary medium">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="M号链接" />
                  <Path Classes="link-demo-icon"
                        Data="M6 6H18V18 M7 17L17 7" />
                </StackPanel>
              </HyperlinkButton>

              <HyperlinkButton Classes="primary large">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="L号链接" />
                  <Path Classes="link-demo-icon"
                        Data="M6 6H18V18 M7 17L17 7" />
                </StackPanel>
              </HyperlinkButton>
            </StackPanel>
          </Border>
        </StackPanel>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
