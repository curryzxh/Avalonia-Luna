<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:luna="https://github.com/curryzxh/Luna"
             xmlns:vm="using:Luna.Mobile.Sample.ViewModels"
             x:Class="Luna.Mobile.Sample.Views.LoadingDemoView"
             x:DataType="vm:LoadingDemoViewModel">
  <ScrollViewer Background="{DynamicResource Luna.Brush.Background.Page}">
    <StackPanel Spacing="24" Margin="0,0,0,28">
      <Border Background="{DynamicResource Luna.Brush.Background.Container}">
        <Grid ColumnDefinitions="56,*,56" MinHeight="56">
          <Button Classes="text"
                  Content="‹"
                  FontSize="34"
                  Padding="0"
                  Command="{Binding BackCommand}" />
          <TextBlock Grid.Column="1"
                     Text="Loading 加载"
                     FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                     FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                     Foreground="{DynamicResource Luna.Brush.Text.Primary}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
        </Grid>
      </Border>

      <StackPanel Margin="16,0" Spacing="8">
        <TextBlock Text="Loading 加载"
                   FontSize="{DynamicResource Luna.FontSize.Title.Large}"
                   FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                   Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
        <TextBlock Text="用于表示页面或操作的加载状态，给予用户反馈的同时减缓等待的焦虑感，由一个或一组反馈动效组成。"
                   FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                   Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                   TextWrapping="Wrap" />
      </StackPanel>

      <StackPanel Spacing="28">
        <StackPanel Spacing="16">
          <StackPanel Margin="16,0" Spacing="4">
            <TextBlock Text="01 类型"
                       FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                       FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                       Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
            <TextBlock Text="纯图标"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          </StackPanel>
          <Border Background="{DynamicResource Luna.Brush.Background.Container}" Margin="16,0" Padding="16">
            <StackPanel Orientation="Horizontal" Spacing="40" VerticalAlignment="Center">
              <luna:Loading Width="40" Height="40" />
              <luna:Loading Theme="Spinner" Width="40" Height="40" />
              <luna:Loading Theme="Dots" Size="40" Width="40" Height="40" />
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="图标加文字（横向）"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                     Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          <Border Background="{DynamicResource Luna.Brush.Background.Container}" Margin="16,0" Padding="16">
            <StackPanel Orientation="Horizontal" Spacing="40" VerticalAlignment="Center">
              <luna:Loading Text="加载中..." />
              <luna:Loading Theme="Spinner" Text="加载中..." />
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="图标加文字（纵向）"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                     Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          <Border Background="{DynamicResource Luna.Brush.Background.Container}" Margin="16,0" Padding="16">
            <StackPanel Orientation="Horizontal" Spacing="40" VerticalAlignment="Center">
              <luna:Loading Text="加载中..." Layout="Vertical" />
              <luna:Loading Theme="Spinner" Text="加载中..." Layout="Vertical" />
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="纯文字"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                     Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          <Border Background="{DynamicResource Luna.Brush.Background.Container}" Margin="16,0" Padding="16">
            <StackPanel Orientation="Horizontal" Spacing="40" VerticalAlignment="Center">
              <luna:Loading Indicator="False" Text="加载中..." />
              <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <luna:Loading Name="InlineLoading"
                                  Theme="Spinner"
                                  IsLoading="False">
                  <TextBlock Text="加载失败"
                             FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                             Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                             VerticalAlignment="Center" />
                </luna:Loading>
                <Button Classes="text"
                        Content="刷新"
                        FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                        Click="OnRefreshClick" />
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="02 组件尺寸"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                     FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                     Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
          <Border Background="{DynamicResource Luna.Brush.Background.Container}" Margin="16,0" Padding="16">
            <StackPanel Spacing="24">
              <StackPanel Spacing="16">
                <TextBlock Text="大尺寸"
                           FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                           Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
                <luna:Loading Size="26" Text="加载中..." />
              </StackPanel>
              <StackPanel Spacing="16">
                <TextBlock Text="中尺寸"
                           FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                           Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
                <luna:Loading Size="22" Text="加载中..." />
              </StackPanel>
              <StackPanel Spacing="16">
                <TextBlock Text="小尺寸"
                           FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                           Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
                <luna:Loading Size="20" Text="加载中..." />
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <StackPanel Margin="16,0" Spacing="4">
            <TextBlock Text="03 加载速度"
                       FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                       FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                       Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
            <TextBlock Text="加载速度调整"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          </StackPanel>
          <Border Background="{DynamicResource Luna.Brush.Background.Container}" Margin="16,0" Padding="16">
            <StackPanel Spacing="16">
              <luna:Loading Name="SpeedLoading" Text="加载中..." />
              <Slider Name="SpeedSlider"
                      Minimum="0"
                      Maximum="10"
                      Value="5"
                      ValueChanged="OnSpeedChanged" />
            </StackPanel>
          </Border>
        </StackPanel>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>

