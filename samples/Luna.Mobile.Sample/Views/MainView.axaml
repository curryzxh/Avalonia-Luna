<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Luna.Mobile.Sample.Views"
             x:Class="Luna.Mobile.Sample.Views.MainView"
             x:DataType="views:MainView">
  <ScrollViewer Background="{DynamicResource Luna.Brush.Background.Page}">
    <StackPanel Margin="16,18,16,24" Spacing="24">
      <StackPanel Spacing="24">
        <Grid ColumnDefinitions="54,Auto" ColumnSpacing="12" HorizontalAlignment="Left">
          <Grid Width="54" Height="40">
            <Border Width="38"
                    Height="8"
                    Margin="9,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="{DynamicResource Luna.Brush.Success}"
                    CornerRadius="{DynamicResource Luna.Radius.Small}">
              <Border.RenderTransform>
                <RotateTransform Angle="3" />
              </Border.RenderTransform>
            </Border>
            <Border Width="12"
                    Height="38"
                    Margin="5,1,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="{DynamicResource Luna.Brush.Brand}"
                    CornerRadius="{DynamicResource Luna.Radius.Small}">
              <Border.RenderTransform>
                <SkewTransform AngleX="-10" />
              </Border.RenderTransform>
            </Border>
            <Border Width="30"
                    Height="8"
                    Margin="6,16,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="{DynamicResource Luna.Brush.Brand.Active}"
                    CornerRadius="{DynamicResource Luna.Radius.Small}">
              <Border.RenderTransform>
                <SkewTransform AngleX="-10" />
              </Border.RenderTransform>
            </Border>
          </Grid>

          <TextBlock Grid.Column="1"
                     Text="Luna Mobile"
                     FontSize="30"
                     FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                     FontStyle="Italic"
                     Foreground="{DynamicResource Luna.Brush.Text.Primary}"
                     VerticalAlignment="Center" />
        </Grid>

        <TextBlock Text="{Binding Title}"
                   FontSize="{DynamicResource Luna.FontSize.Body.Large}"
                   Foreground="{DynamicResource Luna.Brush.Text.Placeholder}" />
      </StackPanel>

      <ItemsControl ItemsSource="{Binding Sections}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Spacing="12" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="views:CatalogSection">
            <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
              <Expander.ContentTransition>
                <PageSlide Duration="0:00:00.200" Orientation="Vertical" />
              </Expander.ContentTransition>
              <Expander.Header>
                <Border Background="{DynamicResource Luna.Brush.Background.Container}">
                  <Grid Height="56" ColumnDefinitions="*,48" Margin="32,0,26,0">
                    <TextBlock Text="{Binding Title}"
                               FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                               FontWeight="{DynamicResource Luna.FontWeight.Medium}"
                               Foreground="{DynamicResource Luna.Brush.Text.Primary}"
                               VerticalAlignment="Center" />
                    <Path Grid.Column="1"
                          Width="28"
                          Height="28"
                          Data="{Binding IconData}"
                          Stroke="{DynamicResource Luna.Brush.Text.Placeholder}"
                          StrokeThickness="2"
                          StrokeLineCap="Square"
                          StrokeJoin="Miter"
                          Fill="Transparent"
                          Stretch="Uniform"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center" />
                  </Grid>
                </Border>
              </Expander.Header>

              <Border Background="{DynamicResource Luna.Brush.Background.Container}">
                <ItemsControl ItemsSource="{Binding Children}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="views:CatalogItem">
                      <Grid Height="56"
                            ColumnDefinitions="*,36"
                            Margin="32,0,26,0"
                            Tag="{Binding Path}"
                            Tapped="OnCatalogItemTapped">
                        <Border Height="1"
                                Background="{DynamicResource Luna.Brush.Border.Divider}"
                                VerticalAlignment="Top"
                                Grid.ColumnSpan="2" />
                        <TextBlock Text="{Binding Name}"
                                   FontSize="{DynamicResource Luna.FontSize.Body.Large}"
                                   Foreground="{DynamicResource Luna.Brush.Text.Primary}"
                                   VerticalAlignment="Center" />
                        <Path Grid.Column="1"
                              Width="18"
                              Height="18"
                              Data="M9.5 17.5L15 12L9.5 6.5"
                              Stroke="{DynamicResource Luna.Brush.Text.Placeholder}"
                              StrokeThickness="2"
                              StrokeLineCap="Square"
                              Fill="Transparent"
                              Stretch="Uniform"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Border>
            </Expander>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </ScrollViewer>
</UserControl>
