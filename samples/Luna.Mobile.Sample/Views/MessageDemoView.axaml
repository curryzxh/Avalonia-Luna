<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Luna.Mobile.Controls"
             x:Class="Luna.Mobile.Sample.Views.MessageDemoView">
  <Grid>
    <ScrollViewer Background="{DynamicResource Luna.Brush.Background.Page}">
      <StackPanel Spacing="24" Margin="0,0,0,28">
        <Border Background="{DynamicResource Luna.Brush.Background.Container}">
          <Grid ColumnDefinitions="56,*,56" MinHeight="56">
            <Button Classes="text"
                    Content="‹"
                    FontSize="34"
                    Padding="0"
                    Click="OnBackClick" />
            <TextBlock Grid.Column="1"
                       Text="Message 消息通知"
                       FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                       FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                       Foreground="{DynamicResource Luna.Brush.Text.Primary}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Grid>
        </Border>

        <StackPanel Margin="16,0" Spacing="8">
          <TextBlock Text="Message 消息通知"
                     FontSize="{DynamicResource Luna.FontSize.Title.Large}"
                     FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                     Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
          <TextBlock Text="用于轻量级反馈或提示，不会打断用户操作。"
                     FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                     Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                     TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Spacing="28">
          <StackPanel Spacing="16">
            <StackPanel Margin="16,0" Spacing="4">
              <TextBlock Text="01 组件类型"
                         FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                         FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                         Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
              <TextBlock Text="消息通知内容为文本、带操作按钮"
                         FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                         Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
            </StackPanel>
            <StackPanel Margin="16,0" Spacing="16">
              <Button Classes="primary outline large"
                      HorizontalAlignment="Stretch"
                      Content="纯文字的通知"
                      Click="OnTextOnlyClick" />
              <Button Classes="primary outline large"
                      HorizontalAlignment="Stretch"
                      Content="带图标的通知"
                      Click="OnIconClick" />
              <Button Classes="primary outline large"
                      HorizontalAlignment="Stretch"
                      Content="带关闭的通知"
                      Click="OnCloseClick" />
              <Button Classes="primary outline large"
                      HorizontalAlignment="Stretch"
                      Content="可滚动的通知"
                      Click="OnMarqueeClick" />
              <Button Classes="primary outline large"
                      HorizontalAlignment="Stretch"
                      Content="带按钮的通知"
                      Click="OnLinkClick" />
            </StackPanel>
          </StackPanel>

          <StackPanel Spacing="16">
            <StackPanel Margin="16,0" Spacing="4">
              <TextBlock Text="02 组件状态"
                         FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                         FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                         Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
              <TextBlock Text="消息组件风格"
                         FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                         Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
            </StackPanel>
            <StackPanel Margin="16,0" Spacing="16">
              <Button Classes="primary outline large"
                      HorizontalAlignment="Stretch"
                      Content="普通通知"
                      Click="OnInfoClick" />
              <Button Classes="primary outline large"
                      HorizontalAlignment="Stretch"
                      Content="成功通知"
                      Click="OnSuccessClick" />
              <Button Classes="primary outline large"
                      HorizontalAlignment="Stretch"
                      Content="警示通知"
                      Click="OnWarningClick" />
              <Button Classes="primary outline large"
                      HorizontalAlignment="Stretch"
                      Content="错误通知"
                      Click="OnErrorClick" />
            </StackPanel>
          </StackPanel>

          <StackPanel Spacing="16">
            <StackPanel Margin="16,0" Spacing="4">
              <TextBlock Text="03 关闭所有通知"
                         FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                         FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                         Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
              <TextBlock Text="关闭所有通知"
                         FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                         Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
            </StackPanel>
            <StackPanel Margin="16,0" Spacing="16">
              <Button Classes="primary outline large"
                      HorizontalAlignment="Stretch"
                      Content="打开多个通知"
                      Click="OnOpenMultipleClick" />
              <Button Classes="primary outline large"
                      HorizontalAlignment="Stretch"
                      Content="关闭所有通知"
                      Click="OnCloseAllClick" />
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </StackPanel>
    </ScrollViewer>

    <controls:MessageHost HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" />
  </Grid>
</UserControl>

