<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Luna.Mobile.Sample.Views.ProgressDemoView">
  <ScrollViewer Background="{DynamicResource Luna.Brush.Background.Page}">
    <StackPanel Spacing="24" Margin="0,0,0,28">
      <StackPanel Margin="16,0" Spacing="8">
        <TextBlock Text="Progress 进度条"
                   FontSize="{DynamicResource Luna.FontSize.Title.Large}"
                   FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                   Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
        <TextBlock Text="用于展示任务当前的进度。"
                   FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                   Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                   TextWrapping="Wrap" />
      </StackPanel>

      <StackPanel Spacing="28">
        <StackPanel Spacing="16">
          <StackPanel Margin="16,0" Spacing="4">
            <TextBlock Text="01 组件类型"
                       FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                       FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                       Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
            <TextBlock Text="线性进度条"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          </StackPanel>

          <Border Background="{DynamicResource Luna.Brush.Background.Container}"
                  Margin="16,0"
                  Padding="16">
            <StackPanel Spacing="16">
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <ProgressBar x:Name="BaseLineProgress"
                             Minimum="0"
                             Maximum="100"
                             Value="80"
                             VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="{Binding #BaseLineProgress.Value, StringFormat='{}{0:F0}%'}"
                           FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                           Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                           VerticalAlignment="Center" />
              </Grid>

              <TextBlock Text="百分比内显"
                         FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                         Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />

              <ProgressBar Classes="plump"
                           Minimum="0"
                           Maximum="100"
                           Value="80"
                           ShowProgressText="True" />

              <TextBlock Text="环形进度条"
                         FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                         Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />

              <Border Background="{DynamicResource Luna.Brush.Background.Component}"
                      CornerRadius="12"
                      Padding="12">
                <TextBlock Text="Avalonia 原生 ProgressBar 暂不支持环形进度条，先保留示例位置占位。"
                           FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                           Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                           TextWrapping="Wrap" />
              </Border>

              <TextBlock Text="微型环形进度条"
                         FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                         Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />

              <Border Background="{DynamicResource Luna.Brush.Background.Component}"
                      CornerRadius="12"
                      Padding="12">
                <TextBlock Text="微型环形进度条占位"
                           FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                           Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
              </Border>
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <StackPanel Margin="16,0" Spacing="4">
            <TextBlock Text="02 组件状态"
                       FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                       FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                       Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
            <TextBlock Text="线性进度条"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          </StackPanel>

          <Border Background="{DynamicResource Luna.Brush.Background.Container}"
                  Margin="16,0"
                  Padding="16">
            <StackPanel Spacing="16">
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <ProgressBar x:Name="NormalLineProgress"
                             Minimum="0"
                             Maximum="100"
                             Value="78" />
                <TextBlock Grid.Column="1"
                           Text="{Binding #NormalLineProgress.Value, StringFormat='{}{0:F0}%'}"
                           FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                           Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
              </Grid>

              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <ProgressBar x:Name="WarningLineProgress"
                             Classes="warning"
                             Minimum="0"
                             Maximum="100"
                             Value="80" />
                <TextBlock Grid.Column="1"
                           Text="{Binding #WarningLineProgress.Value, StringFormat='{}{0:F0}%'}"
                           FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                           Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
              </Grid>

              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <ProgressBar x:Name="ErrorLineProgress"
                             Classes="error"
                             Minimum="0"
                             Maximum="100"
                             Value="80" />
                <TextBlock Grid.Column="1"
                           Text="{Binding #ErrorLineProgress.Value, StringFormat='{}{0:F0}%'}"
                           FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                           Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
              </Grid>

              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <ProgressBar x:Name="SuccessLineProgress"
                             Classes="success"
                             Minimum="0"
                             Maximum="100"
                             Value="80" />
                <TextBlock Grid.Column="1"
                           Text="{Binding #SuccessLineProgress.Value, StringFormat='{}{0:F0}%'}"
                           FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                           Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
              </Grid>

              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <ProgressBar x:Name="ActiveLineProgress"
                             Classes="active"
                             Minimum="0"
                             Maximum="100"
                             Value="78" />
                <TextBlock Grid.Column="1"
                           Text="{Binding #ActiveLineProgress.Value, StringFormat='{}{0:F0}%'}"
                           FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                           Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
              </Grid>
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="百分比内显进度条"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                     Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />

          <Border Background="{DynamicResource Luna.Brush.Background.Container}"
                  Margin="16,0"
                  Padding="16">
            <StackPanel Spacing="16">
              <ProgressBar Classes="plump"
                           Minimum="0"
                           Maximum="100"
                           Value="80"
                           ShowProgressText="True" />
              <ProgressBar Classes="plump"
                           Minimum="0"
                           Maximum="100"
                           Value="100"
                           ShowProgressText="True" />
              <ProgressBar Classes="plump warning"
                           Minimum="0"
                           Maximum="100"
                           Value="80"
                           ShowProgressText="True" />
              <ProgressBar Classes="plump error"
                           Minimum="0"
                           Maximum="100"
                           Value="80"
                           ShowProgressText="True" />
              <ProgressBar Classes="plump active"
                           Minimum="0"
                           Maximum="100"
                           Value="80"
                           ShowProgressText="True" />
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="环形进度条"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                     Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />

          <Border Background="{DynamicResource Luna.Brush.Background.Container}"
                  Margin="16,0"
                  Padding="16">
            <WrapPanel ItemWidth="120" ItemHeight="72">
              <Border Background="{DynamicResource Luna.Brush.Background.Component}"
                      CornerRadius="12"
                      Padding="12"
                      Margin="0,0,12,12">
                <TextBlock Text="30% 占位"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
              </Border>
              <Border Background="{DynamicResource Luna.Brush.Background.Component}"
                      CornerRadius="12"
                      Padding="12"
                      Margin="0,0,12,12">
                <TextBlock Text="warning 占位"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Luna.Brush.Warning}" />
              </Border>
              <Border Background="{DynamicResource Luna.Brush.Background.Component}"
                      CornerRadius="12"
                      Padding="12"
                      Margin="0,0,12,12">
                <TextBlock Text="error 占位"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Luna.Brush.Danger}" />
              </Border>
              <Border Background="{DynamicResource Luna.Brush.Background.Component}"
                      CornerRadius="12"
                      Padding="12"
                      Margin="0,0,12,12">
                <TextBlock Text="success 占位"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Luna.Brush.Success}" />
              </Border>
            </WrapPanel>
          </Border>
        </StackPanel>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
