<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:luna="https://github.com/curryzxh/Luna"
             xmlns:vm="using:Luna.Mobile.Sample.ViewModels"
             x:Class="Luna.Mobile.Sample.Views.PullDownRefreshTabsDemoView"
             x:DataType="vm:PullDownRefreshTabsDemoViewModel">
  <StackPanel Background="{DynamicResource Luna.Brush.Background.Page}"
              Spacing="16">
    <StackPanel Margin="16,0,16,0"
                Spacing="8">
      <TextBlock Text="PullDownRefresh + TabControl"
                 FontSize="{DynamicResource Luna.FontSize.Title.Large}"
                 FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                 Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
      <TextBlock Text="每个页签内部都独立放置一个 PullDownRefresh，用于验证切换 Tab 后重新下拉仍可触发刷新。"
                 FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                 Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                 TextWrapping="Wrap" />
    </StackPanel>

    <Border Margin="16,0,16,16"
            Background="{DynamicResource Luna.Brush.Background.Container}"
            CornerRadius="12">
      <TabControl SelectedIndex="0">
        <TabItem Header="推荐">
          <luna:PullDownRefresh x:Name="FirstTabRefresh"
                                RefreshCommand="{Binding RefreshFirstTabCommand}"
                                RefreshCommandParameter="{Binding #FirstTabRefresh}">
            <StackPanel Margin="0,0,0,16"
                        Background="{DynamicResource Luna.Brush.Background.Page}"
                        Spacing="12">
              <TextBlock Margin="16,16,16,0"
                         Text="{Binding FirstTabRefreshResultText}"
                         FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                         Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
              <Border Margin="16,0,16,0"
                      Height="120"
                      Background="{DynamicResource Luna.Brush.Background.Component}"
                      CornerRadius="12">
                <TextBlock Text="切换页签后返回这里继续下拉"
                           FontSize="{DynamicResource Luna.FontSize.Body.Large}"
                           Foreground="{DynamicResource Luna.Brush.Text.Placeholder}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
              </Border>
              <ItemsControl Margin="16,0,16,0">
                <ItemsControl.Items>
                  <x:String>推荐策略卡片 01</x:String>
                  <x:String>推荐策略卡片 02</x:String>
                  <x:String>推荐策略卡片 03</x:String>
                  <x:String>推荐策略卡片 04</x:String>
                  <x:String>推荐策略卡片 05</x:String>
                  <x:String>推荐策略卡片 06</x:String>
                </ItemsControl.Items>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Margin="0,0,0,12"
                            Padding="16"
                            Background="{DynamicResource Luna.Brush.Background.Container}"
                            CornerRadius="12">
                      <StackPanel Spacing="8">
                        <TextBlock Text="{Binding .}"
                                   FontSize="{DynamicResource Luna.FontSize.Body.Large}"
                                   FontWeight="{DynamicResource Luna.FontWeight.Medium}"
                                   Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
                        <TextBlock Text="下拉到底部后切换到其他 Tab，再切回顶部继续下拉刷新。"
                                   FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                                   Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </luna:PullDownRefresh>
        </TabItem>

        <TabItem Header="关注">
          <luna:PullDownRefresh x:Name="SecondTabRefresh"
                                RefreshCommand="{Binding RefreshSecondTabCommand}"
                                RefreshCommandParameter="{Binding #SecondTabRefresh}">
            <StackPanel Margin="0,0,0,16"
                        Background="{DynamicResource Luna.Brush.Background.Page}"
                        Spacing="12">
              <TextBlock Margin="16,16,16,0"
                         Text="{Binding SecondTabRefreshResultText}"
                         FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                         Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
              <Border Margin="16,0,16,0"
                      Height="120"
                      Background="{DynamicResource Luna.Brush.Background.Component}"
                      CornerRadius="12">
                <TextBlock Text="本页签也有独立的 PullDownRefresh"
                           FontSize="{DynamicResource Luna.FontSize.Body.Large}"
                           Foreground="{DynamicResource Luna.Brush.Text.Placeholder}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
              </Border>
              <ItemsControl Margin="16,0,16,0">
                <ItemsControl.Items>
                  <x:String>关注策略卡片 A</x:String>
                  <x:String>关注策略卡片 B</x:String>
                  <x:String>关注策略卡片 C</x:String>
                  <x:String>关注策略卡片 D</x:String>
                  <x:String>关注策略卡片 E</x:String>
                  <x:String>关注策略卡片 F</x:String>
                </ItemsControl.Items>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Margin="0,0,0,12"
                            Padding="16"
                            Background="{DynamicResource Luna.Brush.Background.Container}"
                            CornerRadius="12">
                      <StackPanel Spacing="8">
                        <TextBlock Text="{Binding .}"
                                   FontSize="{DynamicResource Luna.FontSize.Body.Large}"
                                   FontWeight="{DynamicResource Luna.FontWeight.Medium}"
                                   Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
                        <TextBlock Text="验证 TabControl 重挂载后刷新事件、拖拽状态和回弹逻辑仍然正常。"
                                   FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                                   Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </luna:PullDownRefresh>
        </TabItem>
      </TabControl>
    </Border>
  </StackPanel>
</UserControl>
