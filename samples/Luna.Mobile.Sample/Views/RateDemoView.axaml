<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:luna="https://github.com/curryzxh/Luna"
             xmlns:vm="using:Luna.Mobile.Sample.ViewModels"
             x:Class="Luna.Mobile.Sample.Views.RateDemoView"
             x:DataType="vm:RateDemoViewModel">
  <ScrollViewer Background="{DynamicResource Luna.Brush.Background.Page}">
    <StackPanel Spacing="24" Margin="0,0,0,28">
      
      <StackPanel Margin="16,0" Spacing="8">
        <TextBlock Text="Rate 评分"
                   FontSize="{DynamicResource Luna.FontSize.Title.Large}"
                   FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                   Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
        <TextBlock Text="用于对某行为/事物进行打分。"
                   FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                   Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                   TextWrapping="Wrap" />
      </StackPanel>

      <StackPanel Spacing="28">
        <StackPanel Spacing="16">
          <StackPanel Margin="16,0" Spacing="4">
            <TextBlock Text="01 类型"
                       FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                       FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                       Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
            <TextBlock Text="实心评分"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          </StackPanel>
          <Border Background="{DynamicResource Luna.Brush.Background.Container}" Margin="16,0" Padding="16">
            <luna:Rate Name="BasicRate" Value="3" />
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="自定义数量评分"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                     Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          <Border Background="{DynamicResource Luna.Brush.Background.Container}" Margin="16,0" Padding="16">
            <luna:Rate Count="3" Value="2" />
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="带描述评分"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                     Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          <Border Background="{DynamicResource Luna.Brush.Background.Container}" Margin="16,0" Padding="16">
            <StackPanel Spacing="12">
              <luna:Rate ShowText="True" Texts="{Binding Texts}" Value="1" />
              <luna:Rate ShowText="True" Texts="{Binding Texts}" Value="5" />
              <luna:Rate ShowText="True" Texts="{Binding Texts}" Value="0" />
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="评分弹框位置"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                     Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          <Border Background="{DynamicResource Luna.Brush.Background.Container}" Margin="16,0" Padding="16">
            <StackPanel Spacing="16">
              <luna:Rate ShowText="True" Texts="{Binding Texts}" Placement="Top" Value="3" />
              <luna:Rate ShowText="True" Texts="{Binding Texts}" Placement="Bottom" Value="3" />
              <luna:Rate ShowText="True" Texts="{Binding Texts}" Placement="None" Value="3" />
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <StackPanel Margin="16,0" Spacing="4">
            <TextBlock Text="02 组件状态"
                       FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                       FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                       Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
            <TextBlock Text="只可选全星时"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          </StackPanel>
          <Border Background="{DynamicResource Luna.Brush.Background.Container}" Margin="16,0" Padding="16">
            <luna:Rate Value="0" AllowHalf="False" />
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="可选半星时（点击或滑动）"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                     Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          <Border Background="{DynamicResource Luna.Brush.Background.Container}" Margin="16,0" Padding="16">
            <luna:Rate Value="2.5" AllowHalf="True" />
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <StackPanel Margin="16,0" Spacing="4">
            <TextBlock Text="03 组件样式"
                       FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                       FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                       Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
            <TextBlock Text="评分大小"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          </StackPanel>
          <Border Background="{DynamicResource Luna.Brush.Background.Container}" Margin="16,0" Padding="16">
            <StackPanel Spacing="16">
              <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="大尺寸24"
                           FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                           Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                           VerticalAlignment="Center" />
                <luna:Rate Size="24" Value="3" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="小尺寸20"
                           FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                           Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                           VerticalAlignment="Center" />
                <luna:Rate Size="20" Value="3" />
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="设置评分颜色"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                     Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          <Border Background="{DynamicResource Luna.Brush.Background.Container}" Margin="16,0" Padding="16">
            <StackPanel Spacing="16">
              <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="选中及未选中颜色"
                           FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                           Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                           VerticalAlignment="Center" />
                <luna:Rate Value="3"
                               AllowHalf="True"
                               ActiveBrush="#FFC51C"
                               InactiveBrush="#E8E8E8" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="仅选中颜色"
                           FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                           Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                           VerticalAlignment="Center" />
                <luna:Rate Value="3"
                               AllowHalf="True"
                               ActiveBrush="{DynamicResource Luna.Brush.Success}" />
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <StackPanel Margin="16,0" Spacing="4">
            <TextBlock Text="04 特殊样式"
                       FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                       FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                       Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
            <TextBlock Text="竖向带描述评分"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          </StackPanel>
          <Border Background="{DynamicResource Luna.Brush.Background.Container}" Margin="16,0" Padding="16">
            <StackPanel Spacing="8" HorizontalAlignment="Center">
              <luna:Rate Size="30"
                         ShowText="True"
                         Texts="{Binding SpecialTexts}"
                         Placement="Bottom"
                         Value="{Binding SpecialValue, Mode=TwoWay}" />
              <TextBlock Text="{Binding SpecialDescription}"
                         FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                         Foreground="{Binding SpecialDescriptionBrush}"
                         FontWeight="{Binding SpecialDescriptionFontWeight}"
                         HorizontalAlignment="Center" />
            </StackPanel>
          </Border>
        </StackPanel>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
