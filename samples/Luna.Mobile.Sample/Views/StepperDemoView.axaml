<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Luna.Mobile.Controls"
             x:Class="Luna.Mobile.Sample.Views.StepperDemoView">
  <ScrollViewer Background="{DynamicResource Luna.Brush.Background.Page}">
    <StackPanel Spacing="24" Margin="0,0,0,28">
      <Border Background="{DynamicResource Luna.Brush.Background.Container}">
        <Grid ColumnDefinitions="56,*,56" MinHeight="56">
          <Button Classes="text"
                  Content="‹"
                  FontSize="34"
                  Padding="0"
                  Click="OnBackClick" />
          <TextBlock Grid.Column="1"
                     Text="Stepper 步进器"
                     FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                     FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                     Foreground="{DynamicResource Luna.Brush.Text.Primary}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
        </Grid>
      </Border>

      <StackPanel Margin="16,0" Spacing="8">
        <TextBlock Text="Stepper 步进器"
                   FontSize="{DynamicResource Luna.FontSize.Title.Large}"
                   FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                   Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
        <TextBlock Text="用于数量的增减"
                   FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                   Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                   TextWrapping="Wrap" />
      </StackPanel>

      <StackPanel Spacing="28">
        <StackPanel Spacing="16">
          <StackPanel Margin="16,0" Spacing="4">
            <TextBlock Text="01 类型"
                       FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                       FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                       Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
            <TextBlock Text="基础步进器"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          </StackPanel>
          <Border Background="{DynamicResource Luna.Brush.Background.Container}" Padding="16">
            <controls:Stepper Theme="Filled" Value="3" />
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <StackPanel Margin="16,0" Spacing="4">
            <TextBlock Text="02 组件状态"
                       FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                       FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                       Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
            <TextBlock Text="最大最小状态"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          </StackPanel>
          <Border Background="{DynamicResource Luna.Brush.Background.Container}" Padding="16">
            <StackPanel Orientation="Horizontal" Spacing="24">
              <controls:Stepper Theme="Filled" Minimum="0" Maximum="10" Value="0" />
              <controls:Stepper Theme="Filled" Minimum="0" Maximum="999" Value="999" />
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="禁用状态"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                     Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          <Border Background="{DynamicResource Luna.Brush.Background.Container}" Padding="16">
            <controls:Stepper Theme="Filled" IsDisabled="True" />
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <StackPanel Margin="16,0" Spacing="4">
            <TextBlock Text="03 组件样式"
                       FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                       FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                       Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
            <TextBlock Text="步进器样式"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          </StackPanel>
          <Border Background="{DynamicResource Luna.Brush.Background.Container}" Padding="16">
            <StackPanel Orientation="Horizontal" Spacing="24">
              <controls:Stepper Theme="Filled" Value="3" />
              <controls:Stepper Theme="Outline" Value="3" />
              <controls:Stepper Theme="Default" Value="3" />
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="步进器尺寸"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                     Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          <Border Background="{DynamicResource Luna.Brush.Background.Container}" Padding="16">
            <StackPanel Orientation="Horizontal" Spacing="24">
              <controls:Stepper Theme="Filled" Size="Large" Value="3" Maximum="99" />
              <controls:Stepper Theme="Filled" Size="Medium" Value="3" Maximum="99" />
              <controls:Stepper Theme="Filled" Size="Small" Value="3" Maximum="99" />
            </StackPanel>
          </Border>
        </StackPanel>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
