<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:luna="https://github.com/curryzxh/Luna"
             x:Class="Luna.Mobile.Sample.Views.StepsDemoView">
  <UserControl.Styles>
    <Style Selector="Border.steps-demo-block">
      <Setter Property="Margin" Value="16,0" />
      <Setter Property="Padding" Value="16,16" />
      <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.Container}" />
    </Style>

    <Style Selector="TextBlock.steps-demo-summary">
      <Setter Property="Margin" Value="16,0" />
      <Setter Property="FontSize" Value="{DynamicResource Luna.FontSize.Body.Medium}" />
      <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Text.Secondary}" />
    </Style>

    <Style Selector="Path.steps-demo-icon">
      <Setter Property="Width" Value="16" />
      <Setter Property="Height" Value="16" />
      <Setter Property="StrokeThickness" Value="1.8" />
      <Setter Property="StrokeLineCap" Value="Round" />
      <Setter Property="Stretch" Value="Uniform" />
    </Style>

    <Style Selector="Border.steps-demo-extra-placeholder">
      <Setter Property="Margin" Value="0,4,0,0" />
      <Setter Property="Padding" Value="12" />
      <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.Component}" />
      <Setter Property="CornerRadius" Value="{DynamicResource Luna.Radius.Large}" />
    </Style>
  </UserControl.Styles>

  <ScrollViewer Background="{DynamicResource Luna.Brush.Background.Page}">
    <StackPanel Spacing="24" Margin="0,0,0,28">
      <StackPanel Margin="16,0" Spacing="8">
        <TextBlock Text="Steps 步骤条"
                   FontSize="{DynamicResource Luna.FontSize.Title.Large}"
                   FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                   Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
        <TextBlock Text="用于任务步骤展示或任务进度展示。"
                   FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                   Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                   TextWrapping="Wrap" />
      </StackPanel>

      <StackPanel Spacing="28">
        <StackPanel Spacing="16">
          <TextBlock Text="01 组件类型"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                     FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                     Foreground="{DynamicResource Luna.Brush.Text.Primary}" />

          <StackPanel Spacing="12">
            <TextBlock Classes="steps-demo-summary" Text="水平带序号步骤条" />
            <Border Classes="steps-demo-block">
              <luna:Steps Current="1">
                <luna:StepItem Title="步骤一" Content="辅助信息" />
                <luna:StepItem Title="步骤二" Content="辅助信息" />
                <luna:StepItem Title="步骤三" Content="辅助信息" />
                <luna:StepItem Title="步骤四" Content="辅助信息" />
              </luna:Steps>
            </Border>
          </StackPanel>

          <StackPanel Spacing="12">
            <TextBlock Classes="steps-demo-summary" Text="水平带图标步骤条" />
            <Border Classes="steps-demo-block">
              <luna:Steps Current="1">
                <luna:StepItem Title="步骤一" Content="辅助信息">
                  <luna:StepItem.Icon>
                    <Path Classes="steps-demo-icon"
                          Data="M3 5H13L12 12H4L3 5Z M6 5V3H10V5"
                          Stroke="{DynamicResource Luna.Brush.Text.Placeholder}" />
                  </luna:StepItem.Icon>
                </luna:StepItem>
                <luna:StepItem Title="步骤二" Content="辅助信息">
                  <luna:StepItem.Icon>
                    <Path Classes="steps-demo-icon"
                          Data="M3 5H13L12 12H4L3 5Z M6 5V3H10V5"
                          Stroke="{DynamicResource Luna.Brush.Brand}" />
                  </luna:StepItem.Icon>
                </luna:StepItem>
                <luna:StepItem Title="步骤三" Content="辅助信息">
                  <luna:StepItem.Icon>
                    <Path Classes="steps-demo-icon"
                          Data="M3 5H13L12 12H4L3 5Z M6 5V3H10V5"
                          Stroke="{DynamicResource Luna.Brush.Text.Placeholder}" />
                  </luna:StepItem.Icon>
                </luna:StepItem>
                <luna:StepItem Title="步骤四" Content="辅助信息">
                  <luna:StepItem.Icon>
                    <Path Classes="steps-demo-icon"
                          Data="M3 5H13L12 12H4L3 5Z M6 5V3H10V5"
                          Stroke="{DynamicResource Luna.Brush.Text.Placeholder}" />
                  </luna:StepItem.Icon>
                </luna:StepItem>
              </luna:Steps>
            </Border>
          </StackPanel>

          <StackPanel Spacing="12">
            <TextBlock Classes="steps-demo-summary" Text="水平简略步骤条" />
            <Border Classes="steps-demo-block">
              <luna:Steps StepTheme="Dot" Current="1">
                <luna:StepItem Title="步骤一" Content="辅助信息" />
                <luna:StepItem Title="步骤二" Content="辅助信息" />
                <luna:StepItem Title="步骤三" Content="辅助信息" />
                <luna:StepItem Title="步骤四" Content="辅助信息" />
              </luna:Steps>
            </Border>
          </StackPanel>

          <StackPanel Spacing="12">
            <TextBlock Classes="steps-demo-summary" Text="垂直带序号步骤条" />
            <Border Classes="steps-demo-block">
              <luna:Steps Layout="Vertical" Current="1">
                <luna:StepItem Title="步骤一" Content="可自定义此处内容" />
                <luna:StepItem Title="步骤二" Content="可自定义此处内容" />
                <luna:StepItem Title="步骤三" Content="可自定义此处内容" />
                <luna:StepItem Title="步骤四" Content="可自定义此处内容" />
              </luna:Steps>
            </Border>
          </StackPanel>

          <StackPanel Spacing="12">
            <TextBlock Classes="steps-demo-summary" Text="垂直带图标步骤条" />
            <Border Classes="steps-demo-block">
              <luna:Steps Layout="Vertical" Current="1">
                <luna:StepItem Title="步骤一" Content="可自定义此处内容">
                  <luna:StepItem.Icon>
                    <Path Classes="steps-demo-icon"
                          Data="M3 5H13L12 12H4L3 5Z M6 5V3H10V5"
                          Stroke="{DynamicResource Luna.Brush.Text.Placeholder}" />
                  </luna:StepItem.Icon>
                </luna:StepItem>
                <luna:StepItem Title="步骤二" Content="可自定义此处内容">
                  <luna:StepItem.Icon>
                    <Path Classes="steps-demo-icon"
                          Data="M3 5H13L12 12H4L3 5Z M6 5V3H10V5"
                          Stroke="{DynamicResource Luna.Brush.Brand}" />
                  </luna:StepItem.Icon>
                </luna:StepItem>
                <luna:StepItem Title="步骤三" Content="可自定义此处内容">
                  <luna:StepItem.Icon>
                    <Path Classes="steps-demo-icon"
                          Data="M3 5H13L12 12H4L3 5Z M6 5V3H10V5"
                          Stroke="{DynamicResource Luna.Brush.Text.Placeholder}" />
                  </luna:StepItem.Icon>
                </luna:StepItem>
                <luna:StepItem Title="步骤四" Content="可自定义此处内容">
                  <luna:StepItem.Icon>
                    <Path Classes="steps-demo-icon"
                          Data="M3 5H13L12 12H4L3 5Z M6 5V3H10V5"
                          Stroke="{DynamicResource Luna.Brush.Text.Placeholder}" />
                  </luna:StepItem.Icon>
                </luna:StepItem>
              </luna:Steps>
            </Border>
          </StackPanel>

          <StackPanel Spacing="12">
            <TextBlock Classes="steps-demo-summary" Text="垂直简略步骤条" />
            <Border Classes="steps-demo-block">
              <luna:Steps Layout="Vertical" StepTheme="Dot" Current="1">
                <luna:StepItem Title="步骤一" Content="可自定义此处内容" />
                <luna:StepItem Title="步骤二" Content="可自定义此处内容" />
                <luna:StepItem Title="步骤三" Content="可自定义此处内容" />
                <luna:StepItem Title="步骤四" Content="可自定义此处内容" />
              </luna:Steps>
            </Border>
          </StackPanel>

          <StackPanel Spacing="12">
            <TextBlock Classes="steps-demo-summary" Text="垂直带可自定义此处内容步骤条" />
            <Border Classes="steps-demo-block">
              <luna:Steps Layout="Vertical" StepTheme="Dot" Current="1">
                <luna:StepItem Title="步骤一" Content="可自定义此处内容" />
                <luna:StepItem Title="步骤二" Content="可自定义此处内容">
                  <luna:StepItem.Extra>
                    <Border Classes="steps-demo-extra-placeholder">
                      <TextBlock Text="图片占位"
                                 HorizontalAlignment="Center"
                                 FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                                 Foreground="{DynamicResource Luna.Brush.Text.Placeholder}" />
                    </Border>
                  </luna:StepItem.Extra>
                </luna:StepItem>
                <luna:StepItem Title="步骤三" Content="可自定义此处内容" />
                <luna:StepItem Title="步骤四" Content="可自定义此处内容" />
              </luna:Steps>
            </Border>
          </StackPanel>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="02 组件状态"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                     FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                     Foreground="{DynamicResource Luna.Brush.Text.Primary}" />

          <StackPanel Spacing="12">
            <TextBlock Classes="steps-demo-summary" Text="选项卡状态" />
            <Border Classes="steps-demo-block">
              <luna:Steps Current="1" CurrentStatus="Error">
                <luna:StepItem Title="步骤一" Content="辅助信息" />
                <luna:StepItem Title="步骤二" Content="辅助信息" />
                <luna:StepItem Title="步骤三" Content="辅助信息" />
                <luna:StepItem Title="步骤四" Content="辅助信息" />
              </luna:Steps>
            </Border>
          </StackPanel>

          <Border Classes="steps-demo-block">
            <luna:Steps Current="1" CurrentStatus="Error">
              <luna:StepItem Title="步骤一" Content="辅助信息">
                <luna:StepItem.Icon>
                  <Path Classes="steps-demo-icon"
                        Data="M3 5H13L12 12H4L3 5Z M6 5V3H10V5"
                        Stroke="{DynamicResource Luna.Brush.Text.Placeholder}" />
                </luna:StepItem.Icon>
              </luna:StepItem>
              <luna:StepItem Title="步骤二" Content="辅助信息">
                <luna:StepItem.Icon>
                  <Path Classes="steps-demo-icon"
                        Data="M3 5H13L12 12H4L3 5Z M6 5V3H10V5"
                        Stroke="{DynamicResource Luna.Brush.Brand}" />
                </luna:StepItem.Icon>
              </luna:StepItem>
              <luna:StepItem Title="步骤三" Content="辅助信息">
                <luna:StepItem.Icon>
                  <Path Classes="steps-demo-icon"
                        Data="M3 5H13L12 12H4L3 5Z M6 5V3H10V5"
                        Stroke="{DynamicResource Luna.Brush.Text.Placeholder}" />
                </luna:StepItem.Icon>
              </luna:StepItem>
              <luna:StepItem Title="步骤四" Content="辅助信息">
                <luna:StepItem.Icon>
                  <Path Classes="steps-demo-icon"
                        Data="M3 5H13L12 12H4L3 5Z M6 5V3H10V5"
                        Stroke="{DynamicResource Luna.Brush.Text.Placeholder}" />
                </luna:StepItem.Icon>
              </luna:StepItem>
            </luna:Steps>
          </Border>

          <Border Classes="steps-demo-block">
            <luna:Steps StepTheme="Dot" Current="1" CurrentStatus="Error">
              <luna:StepItem Title="步骤一" Content="辅助信息" />
              <luna:StepItem Title="步骤二" Content="辅助信息" />
              <luna:StepItem Title="步骤三" Content="辅助信息" />
              <luna:StepItem Title="步骤四" Content="辅助信息" />
            </luna:Steps>
          </Border>
        </StackPanel>

        <StackPanel Spacing="16">
          <TextBlock Text="03 特殊类型"
                     Margin="16,0"
                     FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                     FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                     Foreground="{DynamicResource Luna.Brush.Text.Primary}" />

          <StackPanel Spacing="12">
            <TextBlock Classes="steps-demo-summary" Text="垂直自定义步骤条" />
            <Border Classes="steps-demo-block">
              <StackPanel Spacing="0">
                <luna:Steps x:Name="SpecialInteractiveSteps"
                            Layout="Vertical"
                            StepTheme="Dot" />
                <Button Classes="light large"
                        Margin="0,32,0,0"
                        HorizontalAlignment="Stretch"
                        Content="下一步"
                        Click="OnSpecialNextStepClick" />
              </StackPanel>
            </Border>
          </StackPanel>

          <StackPanel Spacing="12">
            <TextBlock Classes="steps-demo-summary" Text="纯展示步骤条" />
            <Border Classes="steps-demo-block">
              <luna:Steps Layout="Vertical"
                          StepTheme="Dot"
                          Current="3"
                          IsReadOnly="True">
                <luna:StepItem Title="步骤展示" Content="可自定义此处内容">
                  <luna:StepItem.Icon>
                    <Path Classes="steps-demo-icon"
                          Data="M3 5H13L12 12H4L3 5Z M6 5V3H10V5"
                          Stroke="{DynamicResource Luna.Brush.Text.Placeholder}" />
                  </luna:StepItem.Icon>
                </luna:StepItem>
                <luna:StepItem Title="步骤展示" Content="可自定义此处内容">
                  <luna:StepItem.Icon>
                    <Path Classes="steps-demo-icon"
                          Data="M3 5H13L12 12H4L3 5Z M6 5V3H10V5"
                          Stroke="{DynamicResource Luna.Brush.Text.Placeholder}" />
                  </luna:StepItem.Icon>
                </luna:StepItem>
                <luna:StepItem Title="步骤展示" Content="可自定义此处内容">
                  <luna:StepItem.Icon>
                    <Path Classes="steps-demo-icon"
                          Data="M3 5H13L12 12H4L3 5Z M6 5V3H10V5"
                          Stroke="{DynamicResource Luna.Brush.Text.Placeholder}" />
                  </luna:StepItem.Icon>
                </luna:StepItem>
                <luna:StepItem Title="步骤展示" Content="可自定义此处内容">
                  <luna:StepItem.Icon>
                    <Path Classes="steps-demo-icon"
                          Data="M3 5H13L12 12H4L3 5Z M6 5V3H10V5"
                          Stroke="{DynamicResource Luna.Brush.Text.Placeholder}" />
                  </luna:StepItem.Icon>
                </luna:StepItem>
              </luna:Steps>
            </Border>
          </StackPanel>
        </StackPanel>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
