<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Luna.Desktop.Controls">
  <Style Selector="controls|Affix">
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="PART_Placeholder">
          <ContentPresenter Content="{TemplateBinding Content}" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="controls|Affix:fixed /template/ Border#PART_Placeholder">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.Container}" />
    <Setter Property="BoxShadow" Value="{DynamicResource Luna.Shadow.Popup}" />
  </Style>
</Styles>
