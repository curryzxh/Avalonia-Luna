<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Luna.Desktop.Controls">
  <Style Selector="controls|Affix">
    <Setter Property="Template">
      <ControlTemplate>
        <ContentPresenter Content="{TemplateBinding Content}" />
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="controls|Affix:fixed">
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{DynamicResource Luna.Brush.Background.Container}"
                BoxShadow="{DynamicResource Luna.Shadow.Popup}"
                Padding="16,12"
                ZIndex="100">
          <ContentPresenter Content="{TemplateBinding Content}" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>
</Styles>
