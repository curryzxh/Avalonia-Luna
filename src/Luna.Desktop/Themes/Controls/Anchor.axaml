<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Luna.Desktop.Controls">
  <Style Selector="controls|AnchorItem">
    <Setter Property="Padding" Value="8,6" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="CornerRadius" Value="{DynamicResource Luna.Radius.Small}" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}"
                CornerRadius="{TemplateBinding CornerRadius}"
                Padding="{TemplateBinding Padding}">
          <Panel>
            <Border Name="PART_Indicator"
                    Width="2"
                    Background="Transparent"
                    VerticalAlignment="Stretch"
                    HorizontalAlignment="Left"
                    CornerRadius="1"
                    Margin="0,2" />
            <TextBlock Text="{TemplateBinding Text}"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0" />
          </Panel>
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="controls|AnchorItem:pointerover">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.Component}" />
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Text.Primary}" />
  </Style>

  <Style Selector="controls|AnchorItem:selected /template/ Border#PART_Indicator">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Brand}" />
  </Style>

  <Style Selector="controls|AnchorItem:selected">
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Brand}" />
    <Setter Property="FontWeight" Value="{DynamicResource Luna.FontWeight.Bold}" />
  </Style>
</Styles>
