<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Luna.Desktop.Controls">
  <Style Selector="controls|BreadcrumbItem">
    <Setter Property="FontSize" Value="{DynamicResource Luna.FontSize.Body.Medium}" />
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Text.Secondary}" />
    <Setter Property="Template">
      <ControlTemplate>
        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
          <ContentPresenter Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            VerticalAlignment="Center" />
          <TextBlock Text="{TemplateBinding Separator}"
                     FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                     Foreground="{DynamicResource Luna.Brush.Text.Placeholder}"
                     VerticalAlignment="Center"
                     Margin="4,0" />
        </StackPanel>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="controls|BreadcrumbItem:last /template/ TextBlock">
    <Setter Property="IsVisible" Value="False" />
  </Style>

  <Style Selector="controls|BreadcrumbItem:last">
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Text.Primary}" />
    <Setter Property="FontWeight" Value="{DynamicResource Luna.FontWeight.Medium}" />
  </Style>
</Styles>
