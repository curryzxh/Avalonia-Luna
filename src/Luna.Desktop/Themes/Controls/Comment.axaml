<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Luna.Desktop.Controls">
  <Style Selector="controls|Comment">
    <Setter Property="Template">
      <ControlTemplate>
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <Border Width="40" Height="40"
                    CornerRadius="{DynamicResource Luna.Radius.Round}"
                    Background="{DynamicResource Luna.Brush.Brand}"
                    ClipToBounds="True"
                    VerticalAlignment="Top">
              <Panel>
                <TextBlock Text="{TemplateBinding AvatarText}"
                           Foreground="{DynamicResource Luna.Brush.Text.Anti}"
                           FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                           FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           IsVisible="{TemplateBinding AvatarSource, Converter={x:Static ObjectConverters.IsNull}}" />
                <Image Source="{TemplateBinding AvatarSource}"
                       Stretch="UniformToFill"
                       IsVisible="{TemplateBinding AvatarSource, Converter={x:Static ObjectConverters.IsNotNull}}" />
              </Panel>
            </Border>
            <StackPanel Spacing="4" VerticalAlignment="Top" MinWidth="0" Grid.Column="1">
              <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="{TemplateBinding Author}"
                           FontWeight="{DynamicResource Luna.FontWeight.Medium}"
                           FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                           Foreground="{DynamicResource Luna.Brush.Text.Primary}"
                           VerticalAlignment="Center" />
                <TextBlock Text="{TemplateBinding Timestamp}"
                           FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                           Foreground="{DynamicResource Luna.Brush.Text.Placeholder}"
                           VerticalAlignment="Center" />
              </StackPanel>
              <TextBlock Text="{TemplateBinding Content}"
                         FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                         Foreground="{DynamicResource Luna.Brush.Text.Primary}"
                         TextWrapping="Wrap"
                         LineHeight="22" />
              <ContentPresenter Content="{TemplateBinding Actions}"
                                IsVisible="{TemplateBinding Actions, Converter={x:Static ObjectConverters.IsNotNull}}"
                                Margin="0,4,0,0" />
            </StackPanel>
          </StackPanel>
          <Border Margin="52,0,0,0">
            <ItemsControl ItemsSource="{TemplateBinding Replies}"
                          IsVisible="{TemplateBinding Replies, Converter={x:Static ObjectConverters.IsNotNull}}"
                          Margin="0,0,0,0">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Spacing="16" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
          </Border>
        </StackPanel>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="controls|Comment:disabled">
    <Setter Property="Opacity" Value="0.5" />
  </Style>
</Styles>
