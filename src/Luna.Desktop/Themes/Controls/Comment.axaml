<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Luna.Desktop.Controls">
  <Style Selector="controls|Comment">
    <Setter Property="Template">
      <ControlTemplate>
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <Border Width="40" Height="40"
                    CornerRadius="{DynamicResource Luna.Radius.Round}"
                    Background="{DynamicResource Luna.Brush.Brand}"
                    VerticalAlignment="Top">
              <TextBlock Text="{TemplateBinding AvatarText}"
                         Foreground="{DynamicResource Luna.Brush.Text.Anti}"
                         FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                         FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Border>
            <StackPanel Spacing="4" VerticalAlignment="Top" MinWidth="0">
              <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="{TemplateBinding Author}"
                           FontWeight="{DynamicResource Luna.FontWeight.Medium}"
                           FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                           Foreground="{DynamicResource Luna.Brush.Text.Primary}"
                           VerticalAlignment="Center" />
                <TextBlock Text="{TemplateBinding Timestamp}"
                           FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                           Foreground="{DynamicResource Luna.Brush.Text.Placeholder}"
                           VerticalAlignment="Center" />
              </StackPanel>
              <TextBlock Text="{TemplateBinding Content}"
                         FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                         Foreground="{DynamicResource Luna.Brush.Text.Primary}"
                         TextWrapping="Wrap"
                         LineHeight="22" />
            </StackPanel>
          </StackPanel>
          <Border Margin="52,0,0,0"
                  BorderBrush="{DynamicResource Luna.Brush.Border.Divider}"
                  BorderThickness="0,0,0,0">
            <StackPanel Name="PART_Replies" Spacing="16" />
          </Border>
        </StackPanel>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="controls|Comment:disabled">
    <Setter Property="Opacity" Value="0.5" />
  </Style>
</Styles>
