<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Luna.Desktop.Controls">
  <Style Selector="controls|DialogHost">
    <Setter Property="Template">
      <ControlTemplate>
        <Panel>
          <Border Name="PART_Overlay"
                  Background="{DynamicResource Luna.Brush.Mask}"
                  IsVisible="{TemplateBinding IsOpen}"
                  ZIndex="1000">
            <Border.Styles>
              <Style Selector="Border">
                <Setter Property="Transitions">
                  <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CubicEaseOut" />
                  </Transitions>
                </Setter>
              </Style>
            </Border.Styles>
          </Border>
          <Border Name="PART_DialogPanel"
                  Background="{DynamicResource Luna.Brush.Background.Container}"
                  CornerRadius="{DynamicResource Luna.Radius.Large}"
                  BoxShadow="{DynamicResource Luna.Shadow.Popup}"
                  Width="{TemplateBinding DialogWidth}"
                  MaxWidth="720"
                  MaxHeight="480"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  IsVisible="{TemplateBinding IsOpen}"
                  ZIndex="1001">
            <Border.Styles>
              <Style Selector="Border">
                <Setter Property="Transitions">
                  <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseOut" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" Easing="CubicEaseOut" />
                  </Transitions>
                </Setter>
              </Style>
            </Border.Styles>
            <Grid RowDefinitions="Auto,*,Auto">
              <Grid Grid.Row="0" ColumnDefinitions="*,Auto"
                    Margin="20,16,12,0">
                <TextBlock Grid.Column="0"
                           Text="{TemplateBinding Title}"
                           FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                           FontSize="{DynamicResource Luna.FontSize.Title.Small}"
                           Foreground="{DynamicResource Luna.Brush.Text.Primary}"
                           VerticalAlignment="Center"
                           IsVisible="{TemplateBinding Title, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                <Button Grid.Column="1"
                        Name="PART_CloseButton"
                        Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="12"
                        Classes="text small"
                        Width="28"
                        Height="28"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        CornerRadius="{DynamicResource Luna.Radius.Default}"
                        VerticalAlignment="Top"
                        IsVisible="{TemplateBinding ShowCloseButton}" />
              </Grid>

              <ScrollViewer Grid.Row="1" Padding="20,12,20,12">
                <ContentPresenter Content="{TemplateBinding Content}" />
              </ScrollViewer>

              <StackPanel Grid.Row="2"
                          Orientation="Horizontal"
                          HorizontalAlignment="Right"
                          Spacing="8"
                          Margin="20,0,20,16">
                <Button Name="PART_CancelButton"
                        Content="{TemplateBinding CancelText}"
                        IsVisible="{TemplateBinding ShowCancelButton}" />
                <Button Name="PART_ConfirmButton"
                        Content="{TemplateBinding ConfirmText}"
                        Classes="primary"
                        IsVisible="{TemplateBinding ConfirmText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
              </StackPanel>
            </Grid>
          </Border>
        </Panel>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="controls|DialogHost.small">
    <Setter Property="DialogWidth" Value="360" />
  </Style>

  <Style Selector="controls|DialogHost /template/ Button#PART_CloseButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.Component}" />
  </Style>

  <Style Selector="controls|DialogHost.large">
    <Setter Property="DialogWidth" Value="600" />
  </Style>

  <Style Selector="controls|DialogHost:confirm-loading /template/ Button#PART_ConfirmButton">
    <Setter Property="IsEnabled" Value="False" />
    <Setter Property="Opacity" Value="0.7" />
  </Style>
</Styles>
