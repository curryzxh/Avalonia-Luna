<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Luna.Desktop.Controls">
  <Style Selector="controls|Guide">
    <Setter Property="Template">
      <ControlTemplate>
        <ContentPresenter Content="{TemplateBinding Content}" />
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="controls|Guide:active">
    <Setter Property="Template">
      <ControlTemplate>
        <Grid>
          <ContentPresenter Content="{TemplateBinding Content}" />
          <Border Name="PART_Overlay"
                  Background="#66000000"
                  IsHitTestVisible="True"
                  ZIndex="998" />
          <Border ZIndex="999"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Background="{DynamicResource Luna.Brush.Background.Container}"
                  BorderBrush="{DynamicResource Luna.Brush.Border.Default}"
                  BorderThickness="1"
                  CornerRadius="{DynamicResource Luna.Radius.Default}"
                  BoxShadow="{DynamicResource Luna.Shadow.Popup}"
                  Padding="24"
                  Width="360"
                  IsHitTestVisible="True">
            <StackPanel Spacing="16">
              <TextBlock Text="{TemplateBinding CurrentTitle}"
                         FontSize="{DynamicResource Luna.FontSize.Title.Medium}"
                         FontWeight="{DynamicResource Luna.FontWeight.Bold}"
                         Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
              <TextBlock Text="{TemplateBinding CurrentDescription}"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                         FontSize="{DynamicResource Luna.FontSize.Body.Medium}" />
              <Border Height="1" Background="{DynamicResource Luna.Brush.Border.Default}" />
              <StackPanel Spacing="8" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="跳过" Classes="tertiary" />
                <Button Content="下一步" Classes="primary" />
              </StackPanel>
            </StackPanel>
          </Border>
        </Grid>
      </ControlTemplate>
    </Setter>
  </Style>
</Styles>
