<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style Selector="Image">
    <Setter Property="Stretch" Value="Uniform" />
  </Style>

  <Style Selector="Image.round">
    <Setter Property="Clip">
      <Template>
        <EllipseGeometry RadiusX="999" RadiusY="999" />
      </Template>
    </Setter>
  </Style>

  <Style Selector="Border.image-placeholder">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.Component}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Luna.Radius.Default}" />
  </Style>

  <Style Selector="Border.image-placeholder.round">
    <Setter Property="CornerRadius" Value="{DynamicResource Luna.Radius.Round}" />
  </Style>
</Styles>
