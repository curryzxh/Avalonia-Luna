<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Luna.Desktop.Controls">
  <Style Selector="controls|ImageViewer">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.Page}" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}"
                BorderBrush="{DynamicResource Luna.Brush.Border.Default}"
                BorderThickness="1"
                CornerRadius="{DynamicResource Luna.Radius.Default}"
                ClipToBounds="True">
          <Grid RowDefinitions="*,Auto">
            <ScrollViewer Grid.Row="0"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Background="{DynamicResource Luna.Brush.Background.Page}">
              <Border Name="PART_ImageContainer"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      RenderTransformOrigin="50%,50%">
                <Image Source="{TemplateBinding Source}"
                       Stretch="Uniform"
                       MaxWidth="800"
                       MaxHeight="600" />
              </Border>
            </ScrollViewer>

            <Border Grid.Row="1"
                    Background="{DynamicResource Luna.Brush.Background.Container}"
                    BorderBrush="{DynamicResource Luna.Brush.Border.Default}"
                    BorderThickness="0,1,0,0"
                    Padding="8,6">
              <StackPanel Orientation="Horizontal"
                          Spacing="4"
                          HorizontalAlignment="Center">
                <Button Name="PART_ZoomOut"
                        Content="&#x2212;"
                        Width="28" Height="28"
                        Padding="0"
                        FontSize="14" />
                <TextBlock VerticalAlignment="Center"
                           Margin="8,0"
                           FontSize="{DynamicResource Luna.FontSize.Body.Small}">
                  <TextBlock.Text>
                    <Binding Path="Zoom" RelativeSource="{RelativeSource TemplatedParent}" StringFormat="{}{0:P0}" />
                  </TextBlock.Text>
                </TextBlock>
                <Button Name="PART_ZoomIn"
                        Content="+"
                        Width="28" Height="28"
                        Padding="0"
                        FontSize="14" />
                <Border Width="1" Background="{DynamicResource Luna.Brush.Border.Default}" Margin="8,4" />
                <Button Name="PART_RotateLeft"
                        Content="&#x21BA;"
                        Width="28" Height="28"
                        Padding="0"
                        FontSize="14" />
                <Button Name="PART_RotateRight"
                        Content="&#x21BB;"
                        Width="28" Height="28"
                        Padding="0"
                        FontSize="14" />
                <Border Width="1" Background="{DynamicResource Luna.Brush.Border.Default}" Margin="8,4" />
                <Button Name="PART_Reset"
                        Content="&#x21BB;&#x2194;"
                        Width="28" Height="28"
                        Padding="0"
                        FontSize="12" />
              </StackPanel>
            </Border>
          </Grid>
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>
</Styles>
