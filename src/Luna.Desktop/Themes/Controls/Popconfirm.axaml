<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Luna.Desktop.Controls">
  <Style Selector="controls|Popconfirm /template/ Popup#PART_Popup > Border">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.Container}" />
    <Setter Property="CornerRadius" Value="{DynamicResource Luna.Radius.Default}" />
    <Setter Property="BoxShadow" Value="{DynamicResource Luna.Shadow.Popup}" />
    <Setter Property="Padding" Value="16" />
  </Style>

  <Style Selector="controls|Popconfirm">
    <Setter Property="Template">
      <ControlTemplate>
        <Grid>
          <ContentPresenter Content="{TemplateBinding Content}" Name="PART_ContentPresenter" />
          <Popup Name="PART_Popup"
                 IsOpen="{TemplateBinding IsOpen, Mode=TwoWay}"
                 Placement="{TemplateBinding Placement}"
                 PlacementTarget="{Binding #PART_ContentPresenter}">
            <Border Background="{DynamicResource Luna.Brush.Background.Container}"
                    CornerRadius="{DynamicResource Luna.Radius.Default}"
                    BoxShadow="{DynamicResource Luna.Shadow.Popup}"
                    Padding="16"
                    MinWidth="200">
              <StackPanel Spacing="12">
                <TextBlock Text="{TemplateBinding PopupContent}"
                           Foreground="{DynamicResource Luna.Brush.Text.Primary}"
                           FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                           TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal"
                            Spacing="8"
                            HorizontalAlignment="Right">
                  <Button Name="PART_CancelButton"
                          Content="{TemplateBinding CancelText}"
                          FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                          MinHeight="28" />
                  <Button Name="PART_ConfirmButton"
                          Content="{TemplateBinding ConfirmText}"
                          Classes="primary"
                          FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                          MinHeight="28" />
                </StackPanel>
              </StackPanel>
            </Border>
          </Popup>
        </Grid>
      </ControlTemplate>
    </Setter>
  </Style>
</Styles>
