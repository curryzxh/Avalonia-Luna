<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Luna.Desktop.Controls">
  <Style Selector="controls|LunaPopup">
    <Setter Property="Template">
      <ControlTemplate>
        <StackPanel>
          <ContentControl Content="{TemplateBinding Anchor}" />
          <Popup Child="{TemplateBinding Content}"
                 IsOpen="{TemplateBinding IsOpen, Mode=TwoWay}"
                 Placement="{TemplateBinding Placement}"
                 PlacementTarget="{TemplateBinding #Anchor_Target}">
          </Popup>
        </StackPanel>
      </ControlTemplate>
    </Setter>
  </Style>
</Styles>
