<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Luna.Desktop.Controls">
  <Style Selector="controls|LunaPopup">
    <Setter Property="Template">
      <ControlTemplate>
        <Grid>
          <ContentPresenter Content="{TemplateBinding Content}" />
          <Popup Name="PART_Popup"
                 IsOpen="{TemplateBinding IsOpen, Mode=TwoWay}"
                 Placement="{TemplateBinding Placement}"
                 IsLightDismissEnabled="{TemplateBinding IsLightDismissEnabled}"
                 PlacementTarget="{TemplateBinding}">
            <Border Background="{DynamicResource Luna.Brush.Background.Container}"
                    BorderBrush="{DynamicResource Luna.Brush.Border.Default}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource Luna.Radius.Default}"
                    BoxShadow="{DynamicResource Luna.Shadow.Popup}"
                    Padding="12">
              <ContentPresenter Content="{TemplateBinding PopupContent}" />
            </Border>
          </Popup>
        </Grid>
      </ControlTemplate>
    </Setter>
  </Style>
</Styles>
