<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Luna.Desktop.Controls">
  <Style Selector="controls|Statistic">
    <Setter Property="Template">
      <ControlTemplate>
        <StackPanel Spacing="4">
          <TextBlock Text="{TemplateBinding Title}"
                     FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                     Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
          <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Bottom">
            <TextBlock Text="{TemplateBinding Prefix}"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                       VerticalAlignment="Bottom"
                       IsVisible="{TemplateBinding Prefix, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            <TextBlock Name="PART_Value"
                       Text="{TemplateBinding Value}"
                       FontSize="{DynamicResource Luna.FontSize.Title.Large}"
                       FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                       Foreground="{DynamicResource Luna.Brush.Text.Primary}" />
            <TextBlock Text="{TemplateBinding Suffix}"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                       VerticalAlignment="Bottom"
                       IsVisible="{TemplateBinding Suffix, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
          </StackPanel>
          <TextBlock Text="{TemplateBinding Description}"
                     FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                     Foreground="{DynamicResource Luna.Brush.Text.Placeholder}"
                     IsVisible="{TemplateBinding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="controls|Statistic:trend-up /template/ TextBlock#PART_Value">
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Success}" />
  </Style>

  <Style Selector="controls|Statistic:trend-down /template/ TextBlock#PART_Value">
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Error}" />
  </Style>

  <Style Selector="controls|Statistic:loading">
    <Setter Property="IsEnabled" Value="False" />
  </Style>

  <Style Selector="controls|Statistic:loading /template/ TextBlock#PART_Value">
    <Setter Property="Text" Value="--" />
  </Style>
</Styles>
