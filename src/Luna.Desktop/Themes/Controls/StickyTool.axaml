<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Luna.Desktop.Controls">
  <Style Selector="controls|StickyTool">
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{DynamicResource Luna.Brush.Background.Container}"
                BorderBrush="{DynamicResource Luna.Brush.Border.Default}"
                BorderThickness="1"
                CornerRadius="{DynamicResource Luna.Radius.Default}"
                BoxShadow="{DynamicResource Luna.Shadow.Popup}"
                Padding="8"
                MinWidth="48">
          <ContentPresenter Content="{TemplateBinding Content}" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="controls|StickyTool:collapsed">
    <Setter Property="Width" Value="48" />
    <Setter Property="Height" Value="48" />
  </Style>
</Styles>
