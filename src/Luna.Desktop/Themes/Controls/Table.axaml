<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Luna.Desktop.Controls">
  <Style Selector="controls|Table">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.Container}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Luna.Radius.Default}" />
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}">
          <ScrollViewer HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto">
            <StackPanel>
              <Border Name="PART_Header"
                      Background="{DynamicResource Luna.Brush.Background.Page}"
                      BorderBrush="{DynamicResource Luna.Brush.Border.Default}"
                      BorderThickness="0,0,0,1"
                      Padding="0"
                      MinHeight="{TemplateBinding RowMinHeight}">
                <ItemsControl ItemsSource="{TemplateBinding Columns}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="controls:TableColumn">
                      <Border MinWidth="{Binding MinWidth}"
                              Width="{Binding Width}"
                              Padding="16,12"
                              VerticalAlignment="Center">
                        <TextBlock Text="{Binding Header}"
                                   FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                                   FontWeight="{DynamicResource Luna.FontWeight.Bold}"
                                   Foreground="{DynamicResource Luna.Brush.Text.Primary}"
                                   TextAlignment="{Binding Alignment}" />
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Border>
              <ItemsPresenter Name="PART_ItemsPresenter" />
            </StackPanel>
          </ScrollViewer>
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="controls|Table > Border > ScrollViewer > StackPanel > Border > ItemsControl > StackPanel > Border">
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="0,0,1,0" />
  </Style>

  <Style Selector="controls|Table /template/ ItemsPresenter > StackPanel > Border">
    <Setter Property="MinHeight" Value="{Binding RowMinHeight, RelativeSource={RelativeSource AncestorType=controls:Table}}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="16,12" />
  </Style>

  <Style Selector="controls|Table:striped /template/ ItemsPresenter > StackPanel > Border:nth-child(odd)">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.Page}" />
  </Style>

  <Style Selector="controls|Table:hoverable /template/ ItemsPresenter > StackPanel > Border:pointerover">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.Component}" />
  </Style>
</Styles>
