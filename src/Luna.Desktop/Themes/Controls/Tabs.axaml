<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style Selector="TabControl.tabs">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="TabControl.tabs /template/ ItemsPresenter#PART_ItemsPresenter">
    <Setter Property="Margin" Value="0" />
  </Style>

  <Style Selector="TabControl.tabs /template/ TabStrip#PART_HeaderPanel">
    <Setter Property="Margin" Value="0,0,0,0" />
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="TabControl.tabs TabItem">
    <Setter Property="Padding" Value="16,10" />
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Text.Secondary}" />
    <Setter Property="FontSize" Value="{DynamicResource Luna.FontSize.Body.Medium}" />
    <Setter Property="FontWeight" Value="{DynamicResource Luna.FontWeight.Medium}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
  </Style>

  <Style Selector="TabControl.tabs TabItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.ComponentActive}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Text.Primary}" />
  </Style>

  <Style Selector="TabControl.tabs TabItem:selected">
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Brand}" />
  </Style>

  <Style Selector="TabControl.tabs TabItem:selected /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="TabControl.tabs TabItem:selected /template/ Border#PART_SelectionIndicator">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Brand}" />
    <Setter Property="Height" Value="2" />
    <Setter Property="CornerRadius" Value="1" />
    <Setter Property="VerticalAlignment" Value="Bottom" />
  </Style>

  <Style Selector="TabControl.tabs:card">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="TabControl.tabs:card TabItem">
    <Setter Property="Padding" Value="16,10" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="CornerRadius" Value="{DynamicResource Luna.Radius.Default}" />
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Text.Secondary}" />
  </Style>

  <Style Selector="TabControl.tabs:card TabItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.ComponentActive}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Text.Primary}" />
  </Style>

  <Style Selector="TabControl.tabs:card TabItem:selected">
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Brand}" />
  </Style>

  <Style Selector="TabControl.tabs:card TabItem:selected /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.ComponentActive}" />
  </Style>

  <Style Selector="TabControl.tabs TabItem:disabled">
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Text.Disabled}" />
  </Style>
</Styles>
