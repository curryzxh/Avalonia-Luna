<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Luna.Desktop.Controls">
  <Style Selector="controls|Timeline">
    <Setter Property="Template">
      <ControlTemplate>
        <StackPanel Spacing="0">
          <ItemsPresenter ItemsPanel="{TemplateBinding ItemsPanel}" />
        </StackPanel>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="controls|TimelineItem">
    <Setter Property="Template">
      <ControlTemplate>
        <Grid ColumnDefinitions="*,Auto,*">
          <ContentPresenter Grid.Column="2"
                            Content="{TemplateBinding Header}"
                            Margin="12,4,0,4"
                            VerticalAlignment="Top"
                            Foreground="{DynamicResource Luna.Brush.Text.Primary}"
                            FontSize="{DynamicResource Luna.FontSize.Body.Medium}" />
          <Grid Grid.Column="1" RowDefinitions="Auto,*">
            <Border Width="10" Height="10"
                    CornerRadius="5"
                    Margin="0,8"
                    Background="{DynamicResource Luna.Brush.Brand}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />
            <Rectangle Grid.Row="1"
                       Width="2"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Stretch"
                       Fill="{DynamicResource Luna.Brush.Border.Weak}" />
          </Grid>
          <StackPanel Grid.Column="0" Margin="0,4,12,4" HorizontalAlignment="Right" VerticalAlignment="Top">
            <TextBlock Text="{TemplateBinding Timestamp}"
                       FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                       Foreground="{DynamicResource Luna.Brush.Text.Placeholder}"
                       HorizontalAlignment="Right" />
          </StackPanel>
          <ContentPresenter Grid.Column="2"
                            Grid.Row="0"
                            Margin="12,0,0,4"
                            Content="{TemplateBinding Content}"
                            FontSize="{DynamicResource Luna.FontSize.Body.Small}"
                            Foreground="{DynamicResource Luna.Brush.Text.Secondary}" />
        </Grid>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="controls|TimelineItem:last /template/ Rectangle">
    <Setter Property="IsVisible" Value="False" />
  </Style>

  <Style Selector="controls|TimelineItem:success /template/ Border">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Success}" />
  </Style>

  <Style Selector="controls|TimelineItem:warning /template/ Border">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Warning}" />
  </Style>

  <Style Selector="controls|TimelineItem:error /template/ Border">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Error}" />
  </Style>

  <Style Selector="controls|TimelineItem:primary /template/ Border">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Brand}" />
  </Style>
</Styles>
