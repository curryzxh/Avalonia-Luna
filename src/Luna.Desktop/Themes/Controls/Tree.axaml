<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style Selector="TreeView">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.Container}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Luna.Radius.Default}" />
    <Setter Property="Padding" Value="4" />
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Text.Primary}" />
    <Setter Property="FontSize" Value="{DynamicResource Luna.FontSize.Body.Medium}" />
  </Style>

  <Style Selector="TreeViewItem">
    <Setter Property="Padding" Value="4,2" />
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Text.Primary}" />
  </Style>

  <Style Selector="TreeViewItem:selected /template/ Border#PART_Header">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Brand.Light}" />
  </Style>

  <Style Selector="TreeViewItem:pointerover /template/ Border#PART_Header">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.ComponentActive}" />
  </Style>
</Styles>
