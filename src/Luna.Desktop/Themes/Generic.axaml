<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Luna.Desktop.Controls">
  <Styles.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://Luna.Desktop/Themes/Index.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Styles.Resources>

  <StyleInclude Source="avares://Luna.Desktop/Themes/Controls/Button.axaml" />
  <StyleInclude Source="avares://Luna.Desktop/Themes/Controls/TextBox.axaml" />
  <StyleInclude Source="avares://Luna.Desktop/Themes/Controls/Badge.axaml" />

  <Design.PreviewWith>
    <Border Padding="24">
      <controls:DesktopBadge Text="Desktop control" />
    </Border>
  </Design.PreviewWith>
</Styles>
