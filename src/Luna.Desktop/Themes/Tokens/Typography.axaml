<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <x:Double x:Key="Luna.FontSize.Body.Small">12</x:Double>
  <x:Double x:Key="Luna.FontSize.Body.Medium">14</x:Double>
  <x:Double x:Key="Luna.FontSize.Title.Small">16</x:Double>
  <x:Double x:Key="Luna.FontSize.Title.Medium">20</x:Double>
  <x:Double x:Key="Luna.FontSize.Title.Large">28</x:Double>
  <FontWeight x:Key="Luna.FontWeight.Regular">Regular</FontWeight>
  <FontWeight x:Key="Luna.FontWeight.Medium">Medium</FontWeight>
  <FontWeight x:Key="Luna.FontWeight.SemiBold">SemiBold</FontWeight>
</ResourceDictionary>
