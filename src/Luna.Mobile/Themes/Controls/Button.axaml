<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style Selector="Button">
    <Setter Property="MinHeight" Value="{DynamicResource Luna.Size.TouchTarget}" />
    <Setter Property="Padding" Value="{DynamicResource Luna.Padding.Control.Medium}" />
    <Setter Property="Background" Value="#E7E7E7" />
    <Setter Property="BorderBrush" Value="#E7E7E7" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Luna.Radius.Default}" />
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Text.Primary}" />
    <Setter Property="FontSize" Value="{DynamicResource Luna.FontSize.Body.Medium}" />
    <Setter Property="FontWeight" Value="{DynamicResource Luna.FontWeight.SemiBold}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="#E7E7E7" />
    <Setter Property="BorderBrush" Value="#E7E7E7" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Text.Primary}" />
  </Style>

  <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="#A6A6A6" />
    <Setter Property="BorderBrush" Value="#A6A6A6" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Text.Primary}" />
  </Style>

  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Brand}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Brand}" />
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Text.Anti}" />
  </Style>

  <Style Selector="Button.primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Brand.Active}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Brand.Active}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Text.Anti}" />
  </Style>

  <Style Selector="Button.primary:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Brand.Active}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Brand.Active}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Text.Anti}" />
  </Style>

  <Style Selector="Button.light">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Brand.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Brand.Subtle}" />
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Brand}" />
  </Style>

  <Style Selector="Button.light:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Brand.Subtle.Active}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Brand.Subtle.Active}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Brand}" />
  </Style>

  <Style Selector="Button.light:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Brand.Subtle.Active}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Brand.Subtle.Active}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Brand.Active}" />
  </Style>

  <Style Selector="Button.danger">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Error}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Error}" />
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Text.Anti}" />
  </Style>

  <Style Selector="Button.danger:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Error}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Error}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Text.Anti}" />
    <Setter Property="Opacity" Value="0.92" />
  </Style>

  <Style Selector="Button.danger:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Error}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Error}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Text.Anti}" />
    <Setter Property="Opacity" Value="0.84" />
  </Style>

  <Style Selector="Button.outline">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Border.Strong}" />
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Text.Primary}" />
  </Style>

  <Style Selector="Button.outline:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.Component}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Text.Primary}" />
  </Style>

  <Style Selector="Button.outline:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.ComponentActive}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Text.Primary}" />
  </Style>

  <Style Selector="Button.primary.outline">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Brand}" />
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Brand}" />
  </Style>

  <Style Selector="Button.primary.outline:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Brand.Light}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Brand}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Brand}" />
  </Style>

  <Style Selector="Button.primary.outline:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.Component}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Brand}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Brand}" />
  </Style>

  <Style Selector="Button.danger.outline">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Error}" />
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Error}" />
  </Style>

  <Style Selector="Button.danger.outline:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.Component}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Error}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Error}" />
  </Style>

  <Style Selector="Button.danger.outline:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.ComponentActive}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Error}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Error}" />
  </Style>

  <Style Selector="Button.light.outline">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Brand.Light}" />
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Brand}" />
  </Style>

  <Style Selector="Button.light.outline:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Brand.Light}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Brand.Light}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Brand}" />
  </Style>

  <Style Selector="Button.light.outline:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.ComponentActive}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Brand.Light}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Brand}" />
  </Style>

  <Style Selector="Button.text">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Text.Primary}" />
  </Style>

  <Style Selector="Button.text:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.Component}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Text.Primary}" />
  </Style>

  <Style Selector="Button.text:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.ComponentActive}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Text.Primary}" />
  </Style>

  <Style Selector="Button.primary.text">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Brand}" />
  </Style>

  <Style Selector="Button.primary.text:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Brand.Light}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Brand}" />
  </Style>

  <Style Selector="Button.primary.text:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.Component}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Brand}" />
  </Style>

  <Style Selector="Button.danger.text">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Error}" />
  </Style>

  <Style Selector="Button.danger.text:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.Component}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Error}" />
  </Style>

  <Style Selector="Button.danger.text:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.ComponentActive}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Error}" />
  </Style>

  <Style Selector="Button.light.text">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Brand}" />
  </Style>

  <Style Selector="Button.light.text:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Brand.Light}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Brand}" />
  </Style>

  <Style Selector="Button.light.text:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.ComponentActive}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Brand}" />
  </Style>

  <Style Selector="Button.ghost">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Text.Anti}" />
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Text.Anti}" />
  </Style>

  <Style Selector="Button.ghost:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="#F2F3F5" />
    <Setter Property="TextBlock.Foreground" Value="#F2F3F5" />
  </Style>

  <Style Selector="Button.ghost:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="#C9CDD4" />
    <Setter Property="TextBlock.Foreground" Value="#C9CDD4" />
  </Style>

  <Style Selector="Button.primary.ghost">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Brand}" />
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Brand}" />
  </Style>

  <Style Selector="Button.primary.ghost:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Brand.Active}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Brand.Active}" />
  </Style>

  <Style Selector="Button.primary.ghost:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Brand.Active}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Brand.Active}" />
  </Style>

  <Style Selector="Button.danger.ghost">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Error}" />
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Error}" />
  </Style>

  <Style Selector="Button.danger.ghost:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Error}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Error}" />
  </Style>

  <Style Selector="Button.danger.ghost:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Error}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Error}" />
    <Setter Property="Opacity" Value="0.84" />
  </Style>

  <Style Selector="Button.large">
    <Setter Property="MinHeight" Value="{DynamicResource Luna.Size.Control.Large}" />
    <Setter Property="Padding" Value="18,12" />
  </Style>

  <Style Selector="Button.small">
    <Setter Property="MinHeight" Value="{DynamicResource Luna.Size.Control.Small}" />
    <Setter Property="Padding" Value="12,7" />
    <Setter Property="FontSize" Value="{DynamicResource Luna.FontSize.Body.Small}" />
  </Style>

  <Style Selector="Button.extra-small">
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="Padding" Value="10,5" />
    <Setter Property="FontSize" Value="{DynamicResource Luna.FontSize.Body.Small}" />
  </Style>

  <Style Selector="Button.square">
    <Setter Property="Width" Value="{DynamicResource Luna.Size.Control.Large}" />
    <Setter Property="MinWidth" Value="{DynamicResource Luna.Size.Control.Large}" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="Button.round">
    <Setter Property="CornerRadius" Value="{DynamicResource Luna.Radius.Circle}" />
  </Style>

  <Style Selector="Button.circle">
    <Setter Property="Width" Value="{DynamicResource Luna.Size.Control.Large}" />
    <Setter Property="MinWidth" Value="{DynamicResource Luna.Size.Control.Large}" />
    <Setter Property="CornerRadius" Value="{DynamicResource Luna.Radius.Circle}" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="Button.rectangle">
    <Setter Property="CornerRadius" Value="0" />
  </Style>

  <Style Selector="Button:disabled /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.Disabled}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Background.Disabled}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Text.Disabled}" />
    <Setter Property="Opacity" Value="1" />
  </Style>

  <Style Selector="Button.primary:disabled /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Brand.Disabled}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Brand.Disabled}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Text.Anti}" />
  </Style>

  <Style Selector="Button.light:disabled /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Brand.Subtle}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Brand.Subtle}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Brand.Disabled}" />
  </Style>

  <Style Selector="Button.outline:disabled /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Border.Strong}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Border.Strong}" />
  </Style>

  <Style Selector="Button.primary.outline:disabled /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Brand.Disabled}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Brand.Disabled}" />
  </Style>

  <Style Selector="Button.danger:disabled /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Error.Disabled}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Error.Disabled}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Text.Disabled}" />
  </Style>

  <Style Selector="Button.danger.outline:disabled /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Error.Disabled}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Error.Disabled}" />
  </Style>

  <Style Selector="Button.text:disabled /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Text.Disabled}" />
  </Style>

  <Style Selector="Button.primary.text:disabled /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Brand.Disabled}" />
  </Style>

  <Style Selector="Button.danger.text:disabled /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Error.Disabled}" />
  </Style>

  <Style Selector="Button.ghost:disabled /template/ ContentPresenter#PART_ContentPresenter">
