<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:luna="https://github.com/curryzxh/Luna">
  <Style Selector="luna|DateTimePickerHost">
    <Setter Property="Template">
      <ControlTemplate>
        <Grid>
          <Border Name="PART_Overlay"
                  Classes="bottom-sheet-overlay"
                  IsVisible="{TemplateBinding IsOverlayVisible}"
                  IsHitTestVisible="{TemplateBinding IsOverlayVisible}" />

          <Border Name="PART_Sheet"
                  Classes="bottom-sheet-panel"
                  Height="{TemplateBinding SheetHeight}"
                  IsVisible="{TemplateBinding IsSheetVisible}"
                  Opacity="0">
            <Border.RenderTransform>
              <TranslateTransform Y="0" />
            </Border.RenderTransform>
            <Grid RowDefinitions="Auto,Auto,*"
                  RowSpacing="12">
              <Grid Classes="bottom-sheet-header"
                    ColumnDefinitions="Auto,*,Auto">
                <Button Name="PART_CancelButton"
                        Classes="text bottom-sheet-cancel"
                        Content="{TemplateBinding CancelText}" />
                <TextBlock Grid.Column="1"
                           Classes="bottom-sheet-title"
                           Text="{TemplateBinding Title}"
                           IsVisible="{TemplateBinding HasTitle}" />
                <Button Name="PART_ConfirmButton"
                        Grid.Column="2"
                        Classes="text bottom-sheet-confirm"
                        Content="{TemplateBinding ConfirmText}" />
              </Grid>

              <Border Classes="bottom-sheet-divider" />

              <ItemsControl ItemsSource="{TemplateBinding Columns}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="12" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="luna:DateTimePickerColumn">
                    <ComboBox Width="92"
                              HorizontalAlignment="Stretch"
                              ItemsSource="{Binding Items}"
                              SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="luna:DateTimePickerColumnItem">
                          <TextBlock Text="{Binding Label}"
                                     TextAlignment="Center" />
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Grid>
          </Border>
        </Grid>
      </ControlTemplate>
    </Setter>
  </Style>
</Styles>
