<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:luna="https://github.com/curryzxh/Luna">
  <Style Selector="luna|DropdownMenu">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="Template">
      <ControlTemplate>
        <Panel ClipToBounds="False">
          <Border Background="{DynamicResource Luna.Brush.Background.Container}"
                  BorderBrush="{DynamicResource Luna.Brush.Border.Subtle}"
                  BorderThickness="0,0,0,1">
            <Grid Name="PART_HeaderHost"
                  ColumnDefinitions="*" />
          </Border>

          <Popup Name="PART_Popup"
                 IsLightDismissEnabled="False"
                 PlacementTarget="{TemplateBinding}">
            <Grid Name="PART_PopupRoot"
                  Width="{Binding Bounds.Width, RelativeSource={RelativeSource TemplatedParent}}">
              <Border Name="PART_Backdrop"
                      Background="{DynamicResource Luna.Brush.Mask}" />
              <Border Name="PART_PanelBorder"
                      Background="{DynamicResource Luna.Brush.Background.Container}"
                      BorderBrush="{DynamicResource Luna.Brush.Border.Subtle}"
                      BorderThickness="0,0,0,1"
                      ClipToBounds="True"
                      MaxHeight="360"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Top">
                <ContentPresenter Name="PART_PanelHost" />
              </Border>
            </Grid>
          </Popup>
        </Panel>
      </ControlTemplate>
    </Setter>
  </Style>
</Styles>
