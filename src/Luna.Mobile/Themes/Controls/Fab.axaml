<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:luna="https://github.com/curryzxh/Luna">
  <Style Selector="luna|Fab">
    <Setter Property="MinWidth" Value="56" />
    <Setter Property="MinHeight" Value="56" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Brand}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Brand}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Text.Anti}" />
    <Setter Property="CornerRadius" Value="{DynamicResource Luna.Radius.Circle}" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="PART_Container"
                MinWidth="{TemplateBinding MinWidth}"
                MinHeight="{TemplateBinding MinHeight}"
                Width="{TemplateBinding Width}"
                Padding="{TemplateBinding Padding}"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}">
          <StackPanel Orientation="Horizontal"
                      Spacing="8"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
            <ContentPresenter Content="{TemplateBinding Icon}"
                              IsVisible="{TemplateBinding HasIcon}"
                              VerticalAlignment="Center" />
            <TextBlock Text="{TemplateBinding Text}"
                       IsVisible="{TemplateBinding HasText}"
                       VerticalAlignment="Center"
                       FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                       FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                       Foreground="{TemplateBinding Foreground}" />
          </StackPanel>
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="luna|Fab:icon-only">
    <Setter Property="Width" Value="56" />
  </Style>

  <Style Selector="luna|Fab:extended">
    <Setter Property="Padding" Value="16,0" />
  </Style>

  <Style Selector="luna|Fab:pointerover /template/ Border#PART_Container">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Brand.Active}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Brand.Active}" />
  </Style>

  <Style Selector="luna|Fab:pressed /template/ Border#PART_Container">
    <Setter Property="Opacity" Value="0.92" />
  </Style>

  <Style Selector="luna|Fab:dragging /template/ Border#PART_Container">
    <Setter Property="Opacity" Value="0.9" />
  </Style>

  <Style Selector="luna|Fab:disabled /template/ Border#PART_Container">
    <Setter Property="Background" Value="{DynamicResource Luna.Brush.Background.Disabled}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Luna.Brush.Border.Weak}" />
  </Style>

  <Style Selector="luna|Fab:disabled /template/ TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Text.Disabled}" />
  </Style>
</Styles>
