<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:luna="https://github.com/curryzxh/Luna">

  <Style Selector="luna|ImageViewer">
    <Setter Property="Template">
      <ControlTemplate>
        <Panel>
          <Popup Name="PART_Popup"
                 IsOpen="{TemplateBinding IsOpen, Mode=TwoWay}"
                 PlacementTarget="{TemplateBinding}"
                 Placement="Center"
                 IsLightDismissEnabled="False"
                 WindowManagerAddShadowHint="False">
            <Border Name="PART_Overlay"
                    Background="#CC000000">
              <Grid>
                <ContentControl Name="PART_ImageContainer"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="360"
                                MaxHeight="500" />

                <Button Name="PART_CloseButton"
                        Classes="text"
                        Content="✕"
                        FontSize="24"
                        Foreground="#FFFFFFFF"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="16,16"
                        Width="44"
                        Height="44" />

                <Button Name="PART_PrevButton"
                        Classes="text"
                        Content="‹"
                        FontSize="36"
                        Foreground="#FFFFFFFF"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="8,0"
                        Width="44"
                        Height="44" />

                <Button Name="PART_NextButton"
                        Classes="text"
                        Content="›"
                        FontSize="36"
                        Foreground="#FFFFFFFF"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="8,0"
                        Width="44"
                        Height="44" />

                <TextBlock Name="PART_IndexText"
                           Foreground="#FFFFFFFF"
                           FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,40" />

                <Button Name="PART_DeleteButton"
                        Classes="text"
                        Content="🗑"
                        FontSize="24"
                        Foreground="#FFFFFFFF"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,12"
                        Width="44"
                        Height="44" />
              </Grid>
            </Border>
          </Popup>
        </Panel>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="luna|ImageViewer:no-index /template/ TextBlock#PART_IndexText">
    <Setter Property="IsVisible" Value="False" />
  </Style>

  <Style Selector="luna|ImageViewer:no-delete /template/ Button#PART_DeleteButton">
    <Setter Property="IsVisible" Value="False" />
  </Style>

</Styles>
