<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style Selector="HyperlinkButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="MinHeight" Value="24" />
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Text.Secondary}" />
    <Setter Property="FontSize" Value="{DynamicResource Luna.FontSize.Body.Small}" />
    <Setter Property="FontWeight" Value="{DynamicResource Luna.FontWeight.SemiBold}" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="HyperlinkButton /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="TextBlock.Foreground" Value="{TemplateBinding Foreground}" />
  </Style>

  <Style Selector="HyperlinkButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Opacity" Value="0.8" />
    <Setter Property="TextBlock.Foreground" Value="{TemplateBinding Foreground}" />
  </Style>

  <Style Selector="HyperlinkButton:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Opacity" Value="0.65" />
    <Setter Property="TextBlock.Foreground" Value="{TemplateBinding Foreground}" />
  </Style>

  <Style Selector="HyperlinkButton.primary">
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Brand}" />
  </Style>

  <Style Selector="HyperlinkButton.danger">
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Error}" />
  </Style>

  <Style Selector="HyperlinkButton.success">
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Success}" />
  </Style>

  <Style Selector="HyperlinkButton.warning">
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Warning}" />
  </Style>

  <Style Selector="HyperlinkButton.large">
    <Setter Property="FontSize" Value="{DynamicResource Luna.FontSize.Body.Large}" />
    <Setter Property="MinHeight" Value="28" />
  </Style>

  <Style Selector="HyperlinkButton.medium">
    <Setter Property="FontSize" Value="{DynamicResource Luna.FontSize.Body.Medium}" />
    <Setter Property="MinHeight" Value="26" />
  </Style>

  <Style Selector="HyperlinkButton.small">
    <Setter Property="FontSize" Value="{DynamicResource Luna.FontSize.Body.Small}" />
    <Setter Property="MinHeight" Value="24" />
  </Style>

  <Style Selector="HyperlinkButton.underline /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="TextBlock.TextDecorations" Value="Underline" />
  </Style>

  <Style Selector="HyperlinkButton:disabled /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Opacity" Value="1" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource Luna.Brush.Text.Disabled}" />
  </Style>
</Styles>
