<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Luna.Mobile.Controls">
  <Style Selector="controls|LoadingIndicator">
    <Setter Property="Foreground" Value="{DynamicResource Luna.Brush.Brand}" />
  </Style>

  <Style Selector="controls|Loading">
    <Setter Property="Template">
      <ControlTemplate>
        <Grid>
          <ContentPresenter Name="PART_ContentPresenter"
                            Content="{TemplateBinding Content}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />

          <Border Name="PART_LoadingOverlay"
                  Background="{DynamicResource Luna.Brush.Background.Container}"
                  Opacity="0.85"
                  IsVisible="{TemplateBinding ShowStandalone}">
            <StackPanel Orientation="{TemplateBinding Layout}"
                        Spacing="12"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
              <controls:LoadingIndicator Theme="{TemplateBinding Theme}"
                                         Size="{TemplateBinding Size}"
                                         Duration="{TemplateBinding Duration}"
                                         IsVisible="{TemplateBinding Indicator}" />
              <TextBlock Text="{TemplateBinding Text}"
                         IsVisible="{TemplateBinding ShowText}"
                         Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                         FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                         TextAlignment="Center" />
            </StackPanel>
          </Border>

          <Border Name="PART_OverlayOnContent"
                  Background="{DynamicResource Luna.Brush.Background.Container}"
                  Opacity="0.6"
                  IsVisible="{TemplateBinding ShowOverlay}">
            <StackPanel Orientation="{TemplateBinding Layout}"
                        Spacing="12"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
              <controls:LoadingIndicator Theme="{TemplateBinding Theme}"
                                         Size="{TemplateBinding Size}"
                                         Duration="{TemplateBinding Duration}"
                                         IsVisible="{TemplateBinding Indicator}" />
              <TextBlock Text="{TemplateBinding Text}"
                         Foreground="{DynamicResource Luna.Brush.Text.Secondary}"
                         FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                         TextAlignment="Center"
                         IsVisible="{TemplateBinding ShowText}" />
            </StackPanel>
          </Border>
        </Grid>
      </ControlTemplate>
    </Setter>
  </Style>
</Styles>
