<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:luna="https://github.com/curryzxh/Luna">
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Button.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Fab.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Footer.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Guide.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/TextBox.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/ToggleSwitch.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/CheckBox.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/RadioButton.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Cascader.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/SearchBar.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/NavBar.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Stepper.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Steps.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/BottomSheetShared.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/DateTimePicker.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Indexes.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Badge.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Avatar.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Cell.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Collapse.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Tag.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Divider.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Dialog.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/DropdownMenu.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/ActionSheet.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Drawer.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Empty.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Loading.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Link.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Message.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/NoticeBar.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Overlay.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Picker.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/PullDownRefresh.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Rate.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Skeleton.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/SwipeCell.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Progress.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Toast.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Watermark.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Popover.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/ImageViewer.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Slider.axaml" />
  <StyleInclude Source="avares://Luna.Mobile/Themes/Controls/Segmented.axaml" />

  <Design.PreviewWith>
    <Border Padding="24">
      <luna:MobileActionChip Text="Mobile control" IsActive="True" />
    </Border>
  </Design.PreviewWith>

  <Style Selector="luna|MobileActionChip">
    <Setter Property="MinHeight" Value="{DynamicResource Luna.Size.TouchTarget}" />
    <Setter Property="Padding" Value="{DynamicResource Luna.Padding.Control.Medium}" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{DynamicResource Luna.Brush.Background.Component}"
                BorderBrush="{DynamicResource Luna.Brush.Border.Default}"
                BorderThickness="1"
                CornerRadius="{DynamicResource Luna.Radius.Circle}"
                Padding="{TemplateBinding Padding}">
          <TextBlock Text="{TemplateBinding Text}"
                     Foreground="{DynamicResource Luna.Brush.Text.Primary}"
                     FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                     FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="luna|MobileActionChip:active">
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{DynamicResource Luna.Brush.Brand}"
                BorderBrush="{DynamicResource Luna.Brush.Brand}"
                BorderThickness="1"
                CornerRadius="{DynamicResource Luna.Radius.Circle}"
                Padding="{TemplateBinding Padding}">
          <TextBlock Text="{TemplateBinding Text}"
                     Foreground="{DynamicResource Luna.Brush.Text.Anti}"
                     FontSize="{DynamicResource Luna.FontSize.Body.Medium}"
                     FontWeight="{DynamicResource Luna.FontWeight.SemiBold}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>
</Styles>
