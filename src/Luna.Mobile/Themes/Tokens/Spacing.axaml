<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">
  <sys:Double x:Key="Luna.Spacing.1">4</sys:Double>
  <sys:Double x:Key="Luna.Spacing.2">8</sys:Double>
  <sys:Double x:Key="Luna.Spacing.3">12</sys:Double>
  <sys:Double x:Key="Luna.Spacing.4">16</sys:Double>
  <sys:Double x:Key="Luna.Spacing.5">20</sys:Double>
  <sys:Double x:Key="Luna.Spacing.6">24</sys:Double>
  <sys:Double x:Key="Luna.Spacing.8">32</sys:Double>

  <Thickness x:Key="Luna.Padding.Control.Medium">16,10</Thickness>
  <Thickness x:Key="Luna.Padding.Card">16</Thickness>
  <Thickness x:Key="Luna.Padding.Page">24</Thickness>
</ResourceDictionary>
